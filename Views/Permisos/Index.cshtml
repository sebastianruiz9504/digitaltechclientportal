@model DigitalTechClientPortal.Models.PermisosIndexVm

@{
    ViewData["Title"] = "Permisos";
    var ok = TempData["PermisosOk"] as string;
    var error = TempData["PermisosError"] as string;
}

<section class="space-y-6">
    <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
            <p class="text-sm font-medium text-slate-500">@Model.ClienteNombre</p>
            <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Permisos</h1>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ok))
    {
        <div class="rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">@ok</div>
    }

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">@error</div>
    }

    @if (!Model.PermissionColumnsAvailable)
    {
        <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            @DigitalTechClientPortal.Services.PortalPermissionService.BuildMissingColumnsMessage()
        </div>
    }

    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Agregar usuario</h2>
        <form asp-action="Guardar" asp-controller="Permisos" method="post" class="mt-4 space-y-4">
            @Html.AntiForgeryToken()

            <div class="grid gap-4 md:grid-cols-2">
                <label class="block">
                    <span class="text-sm font-medium text-slate-700">Correo</span>
                    <input name="Email" type="email" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-100" />
                </label>
                <label class="block">
                    <span class="text-sm font-medium text-slate-700">Nombre</span>
                    <input name="Nombre" type="text" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-100" />
                </label>
            </div>

            <div>
                <div class="mb-2 text-sm font-medium text-slate-700">Paginas</div>
                <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
                    @foreach (var modulo in Model.Modulos)
                    {
                        <label class="flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2 text-sm text-slate-700">
                            <input type="checkbox" name="ModulosSeleccionados" value="@modulo.Key" class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" />
                            <i class="ti @modulo.Icon text-base text-slate-500"></i>
                            <span>@modulo.Label</span>
                        </label>
                    }
                </div>
            </div>

            <label class="inline-flex items-center gap-2 text-sm font-medium text-slate-700">
                <input type="checkbox" name="Activo" value="true" checked class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" />
                Usuario activo
            </label>
            <input type="hidden" name="Activo" value="false" />

            <div>
                <button type="submit" class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
                    <i class="ti ti-device-floppy"></i>
                    Guardar
                </button>
            </div>
        </form>
    </div>

    <div class="space-y-3">
        <h2 class="text-lg font-semibold text-slate-900">Usuarios asignados</h2>

        @if (!Model.Usuarios.Any())
        {
            <div class="rounded-md border border-slate-200 bg-white px-4 py-4 text-sm text-slate-600">No hay usuarios asignados.</div>
        }

        @foreach (var usuario in Model.Usuarios)
        {
            <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                <form asp-action="Guardar" asp-controller="Permisos" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@usuario.Id" />

                    <div class="grid gap-4 md:grid-cols-2">
                        <label class="block">
                            <span class="text-sm font-medium text-slate-700">Correo</span>
                            <input name="Email" value="@usuario.Email" type="email" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-100" />
                        </label>
                        <label class="block">
                            <span class="text-sm font-medium text-slate-700">Nombre</span>
                            <input name="Nombre" value="@usuario.Nombre" type="text" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-100" />
                        </label>
                    </div>

                    <div>
                        <div class="mb-2 text-sm font-medium text-slate-700">Paginas</div>
                        <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
                            @foreach (var modulo in Model.Modulos)
                            {
                                var isChecked = usuario.ModulosSeleccionados.Contains(modulo.Key, StringComparer.OrdinalIgnoreCase);
                                <label class="flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2 text-sm text-slate-700">
                                    <input type="checkbox" name="ModulosSeleccionados" value="@modulo.Key" checked="@isChecked" class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" />
                                    <i class="ti @modulo.Icon text-base text-slate-500"></i>
                                    <span>@modulo.Label</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <label class="inline-flex items-center gap-2 text-sm font-medium text-slate-700">
                            <input type="checkbox" name="Activo" value="true" checked="@usuario.Activo" class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" />
                            Usuario activo
                        </label>
                        <input type="hidden" name="Activo" value="false" />

                        <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
                            <i class="ti ti-device-floppy"></i>
                            Guardar cambios
                        </button>
                    </div>
                </form>

                <form asp-action="Eliminar" asp-controller="Permisos" method="post" class="mt-3" onsubmit="return confirm('¿Eliminar este usuario?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@usuario.Id" />
                    <button type="submit" class="inline-flex items-center gap-2 rounded-md border border-rose-200 px-3 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50">
                        <i class="ti ti-trash"></i>
                        Eliminar
                    </button>
                </form>
            </div>
        }
    </div>
</section>
