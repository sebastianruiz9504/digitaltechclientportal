@model DigitalTechClientPortal.Models.SeguridadVM
@using System.Globalization
@{
    ViewData["Title"] = "Plan de trabajo de seguridad";
    var es = CultureInfo.GetCultureInfo("es-CO");
    var plan = Model.PlanTrabajoAi;
    var permissionStatus = Model.PermissionStatus ?? new DigitalTechClientPortal.Models.SecurityPermissionStatus();
    var hasMissingPermissions = permissionStatus.HasMissingRequiredScopes;
    var currentReturnUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";

    string RiskClass(string? risk)
    {
        var value = (risk ?? "").Trim().ToLowerInvariant();
        return value switch
        {
            "critico" or "crítico" or "alto" => "danger",
            "medio" => "warning",
            "bajo" => "success",
            _ => "info"
        };
    }

    string PriorityClass(string? priority)
    {
        var value = (priority ?? "").Trim().ToLowerInvariant();
        return value switch
        {
            "p0" or "critica" or "crítica" or "alta" => "danger",
            "p1" or "media" => "warning",
            "p2" or "baja" => "info",
            _ => "muted"
        };
    }
}

<style>
  .workplan-page {
    display: grid;
    gap: 18px;
  }

  .workplan-panel {
    background: #ffffff;
    border: 1px solid #dbe4ef;
    border-radius: 8px;
    box-shadow: 0 8px 22px rgba(4, 16, 33, 0.08);
  }

  .workplan-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    align-items: start;
    padding: 24px;
  }

  .workplan-eyebrow {
    margin: 0 0 8px;
    color: #65758b;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .workplan-title {
    margin: 0;
    color: #0b1220;
    font-size: 1.9rem;
    font-weight: 650;
    line-height: 1.15;
  }

  .workplan-copy {
    max-width: 920px;
    margin: 12px 0 0;
    color: #52647a;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .workplan-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .workplan-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    width: fit-content;
    min-height: 30px;
    padding: 0 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .workplan-pill.success { color: #166534; background: #dcfce7; }
  .workplan-pill.warning { color: #92400e; background: #fef3c7; }
  .workplan-pill.danger { color: #991b1b; background: #fee2e2; }
  .workplan-pill.info { color: #075985; background: #e0f2fe; }
  .workplan-pill.muted { color: #475569; background: #e2e8f0; }

  .workplan-alert {
    padding: 14px 16px;
    color: #92400e;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 8px;
  }

  .workplan-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
    gap: 18px;
  }

  .workplan-section {
    padding: 18px;
  }

  .workplan-section-title {
    margin: 0 0 14px;
    color: #0b1220;
    font-size: 1rem;
    font-weight: 650;
  }

  .workplan-summary {
    color: #334155;
    line-height: 1.62;
  }

  .workplan-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .workplan-threat,
  .workplan-action {
    display: grid;
    gap: 10px;
    padding: 14px;
    background: #f8fbff;
    border: 1px solid #e3ebf5;
    border-radius: 8px;
  }

  .workplan-threat-top,
  .workplan-action-top {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    justify-content: space-between;
  }

  .workplan-item-title {
    margin: 0;
    color: #0b1220;
    font-size: 0.98rem;
    font-weight: 650;
  }

  .workplan-text {
    margin: 0;
    color: #52647a;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .workplan-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: #64748b;
    font-size: 0.83rem;
  }

  .workplan-steps {
    display: grid;
    gap: 8px;
    margin: 2px 0 0;
    padding: 0;
    list-style: none;
  }

  .workplan-step {
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    padding: 10px;
    background: #ffffff;
    border: 1px solid #e5edf6;
    border-radius: 8px;
  }

  .workplan-step-number {
    display: inline-grid;
    width: 30px;
    height: 30px;
    place-items: center;
    color: #ffffff;
    background: #0f766e;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .workplan-empty {
    padding: 18px;
    color: #64748b;
    background: #f8fbff;
    border: 1px dashed #cbd5e1;
    border-radius: 8px;
  }

  @@media (max-width: 980px) {
    .workplan-hero,
    .workplan-grid {
      grid-template-columns: 1fr;
    }

    .workplan-actions {
      justify-content: flex-start;
    }

    .workplan-title {
      font-size: 1.55rem;
    }
  }
</style>

<div id="securityAiPlanExport" class="container-fluid py-4 workplan-page" data-ai-plan-export>
  <section class="workplan-panel workplan-hero">
    <div>
      <p class="workplan-eyebrow">Azure OpenAI + Microsoft Graph</p>
      <h2 class="workplan-title">Plan de trabajo de seguridad</h2>
      <p class="workplan-copy">
        Plan accionable generado a partir de alertas, incidentes, usuarios en riesgo, dispositivos, Secure Score y controles recomendados del tenant.
      </p>
      <div class="workplan-meta mt-3">
        <span><i class="ti ti-calendar"></i> @((Model.From?.ToString("dd MMM yyyy", es) ?? "Sin inicio")) - @((Model.To?.ToString("dd MMM yyyy", es) ?? "Hoy"))</span>
        <span><i class="ti ti-database-search"></i> @Model.DataSources.Count fuente(s)</span>
        <span><i class="ti ti-clock"></i> @(plan?.GeneratedAtLocal ?? DateTimeOffset.Now.ToString("yyyy-MM-dd HH:mm", es))</span>
      </div>
    </div>
    <div class="workplan-actions" data-pdf-exclude>
      <a class="btn btn-outline-secondary" href='@Url.Action("Panel","Seguridad", new { from = Model.From?.ToString("yyyy-MM-dd"), to = Model.To?.ToString("yyyy-MM-dd") })'>
        <i class="ti ti-arrow-left"></i> Volver al panel
      </a>
      <a class="btn btn-primary" href='@Url.Action("PlanTrabajo","Seguridad", new { from = Model.From?.ToString("yyyy-MM-dd"), to = Model.To?.ToString("yyyy-MM-dd"), top = 80 })'
         data-ai-loading="true"
         data-ai-loading-title="Regenerando plan de seguridad con AI"
         data-ai-loading-copy="Estamos consultando de nuevo las señales de seguridad y preparando acciones paso a paso."
         data-ai-loading-disclaimer="Puede tardar cerca de 30 segundos. Mantén esta ventana abierta mientras se genera el plan.">
        <i class="ti ti-sparkles"></i> Regenerar
      </a>
      @if (plan != null)
      {
        <button type="button"
                class="btn btn-outline-primary"
                data-ai-plan-pdf="#securityAiPlanExport"
                data-pdf-filename="plan-seguridad-@DateTimeOffset.Now.ToString("yyyyMMdd-HHmm")">
          <i class="ti ti-file-type-pdf"></i> Descargar PDF
        </button>
      }
    </div>
  </section>

  @if (hasMissingPermissions)
  {
    <div class="workplan-alert">
      <strong>Faltan permisos de Microsoft Graph.</strong>
      <p class="mb-2 mt-1">
        El plan AI necesita leer el módulo de seguridad completo. El token actual tiene @permissionStatus.GrantedRequiredCount de @permissionStatus.RequiredCount permisos requeridos.
      </p>
      <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary btn-sm" href='@Url.Action("Consent","Login", new { returnUrl = currentReturnUrl, admin = false })'>Pedir consentimiento</a>
        <a class="btn btn-outline-primary btn-sm" href='@Url.Action("Consent","Login", new { returnUrl = currentReturnUrl, admin = true })'>Consentimiento admin</a>
      </div>
    </div>
  }
  else if (!string.IsNullOrWhiteSpace(Model.GraphError))
  {
    <div class="workplan-alert">
      <strong>No se pudo completar la lectura del tenant.</strong>
      @Model.GraphError
    </div>
  }
  else if (!string.IsNullOrWhiteSpace(Model.AiPlanError))
  {
    <div class="workplan-alert">
      <strong>No se pudo generar el plan AI.</strong>
      @Model.AiPlanError
    </div>
  }

  @if (plan == null)
  {
    <div class="workplan-empty">
      No hay plan disponible para mostrar todavía.
    </div>
  }
  else
  {
    <section class="workplan-grid">
      <div class="workplan-panel workplan-section">
        <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
          <h3 class="workplan-section-title mb-0">Resumen ejecutivo</h3>
          <span class="workplan-pill @RiskClass(plan.TenantRiskLevel)">
            <i class="ti ti-shield-half"></i> @plan.TenantRiskLevel
          </span>
        </div>
        <p class="workplan-summary">@plan.ExecutiveSummary</p>
        <p class="workplan-text"><strong>Lectura del riesgo:</strong> @plan.TenantRiskRationale</p>

        @if (plan.MissingData.Any())
        {
          <h3 class="workplan-section-title mt-4">Datos faltantes</h3>
          <ul class="workplan-list">
            @foreach (var item in plan.MissingData)
            {
              <li class="workplan-text"><i class="ti ti-info-circle"></i> @item</li>
            }
          </ul>
        }

        @if (plan.Assumptions.Any())
        {
          <h3 class="workplan-section-title mt-4">Supuestos</h3>
          <ul class="workplan-list">
            @foreach (var item in plan.Assumptions)
            {
              <li class="workplan-text"><i class="ti ti-checkup-list"></i> @item</li>
            }
          </ul>
        }
      </div>

      <div class="workplan-panel workplan-section">
        <h3 class="workplan-section-title">Amenazas traducidas</h3>
        @if (plan.Threats.Any())
        {
          <ul class="workplan-list">
            @foreach (var threat in plan.Threats)
            {
              <li class="workplan-threat">
                <div class="workplan-threat-top">
                  <p class="workplan-item-title">@threat.Title</p>
                  <span class="workplan-pill @RiskClass(threat.Severity)">@threat.Severity</span>
                </div>
                <p class="workplan-text">@threat.PlainLanguageSummary</p>
                <p class="workplan-text"><strong>Traducción:</strong> @threat.ThreatTranslation</p>
                <div class="workplan-meta">
                  <span><i class="ti ti-user"></i> @(string.IsNullOrWhiteSpace(threat.AffectedUser) ? "Usuario no identificado" : threat.AffectedUser)</span>
                  <span><i class="ti ti-device-desktop"></i> @(string.IsNullOrWhiteSpace(threat.AffectedDevice) ? "Dispositivo no identificado" : threat.AffectedDevice)</span>
                  <span><i class="ti ti-calendar-event"></i> @(string.IsNullOrWhiteSpace(threat.Date) ? "Sin fecha" : threat.Date)</span>
                </div>
                <p class="workplan-text"><strong>Impacto:</strong> @threat.BusinessImpact</p>
                <p class="workplan-text"><strong>Evidencia:</strong> @threat.Evidence</p>
                <p class="workplan-text"><strong>Acción inmediata:</strong> @threat.ImmediateAction</p>
              </li>
            }
          </ul>
        }
        else
        {
          <div class="workplan-empty">No se identificaron amenazas puntuales en los datos consultados.</div>
        }
      </div>
    </section>

    <section class="workplan-panel workplan-section">
      <h3 class="workplan-section-title">Acciones recomendadas</h3>
      @if (plan.Actions.Any())
      {
        <ul class="workplan-list">
          @foreach (var action in plan.Actions)
          {
            <li class="workplan-action">
              <div class="workplan-action-top">
                <p class="workplan-item-title">@action.Title</p>
                <span class="workplan-pill @PriorityClass(action.Priority)">@action.Priority</span>
              </div>
              <p class="workplan-text"><strong>Por qué importa:</strong> @action.WhyItMatters</p>
              <div class="workplan-meta">
                <span><i class="ti ti-user-cog"></i> Responsable: @action.Owner</span>
                <span><i class="ti ti-gauge"></i> Esfuerzo: @action.Effort</span>
                <span><i class="ti ti-target-arrow"></i> Resultado: @action.ExpectedOutcome</span>
              </div>
              <ul class="workplan-steps">
                @foreach (var step in action.Steps.OrderBy(s => s.Order))
                {
                  <li class="workplan-step">
                    <span class="workplan-step-number">@step.Order</span>
                    <div>
                      <p class="workplan-item-title">@step.Portal</p>
                      <p class="workplan-text"><strong>Ruta:</strong> @step.ClickPath</p>
                      <p class="workplan-text">@step.Instruction</p>
                      <p class="workplan-text"><strong>Validación:</strong> @step.Validation</p>
                    </div>
                  </li>
                }
              </ul>
            </li>
          }
        </ul>
      }
      else
      {
        <div class="workplan-empty">No hay acciones generadas por AI para esta carga.</div>
      }
    </section>

    <section class="workplan-panel workplan-section">
      <h3 class="workplan-section-title">Hallazgos usados para generar este plan</h3>
      <div class="workplan-meta mb-3">
        <span><i class="ti ti-alert-triangle"></i> @Model.Alertas.Count alertas</span>
        <span><i class="ti ti-siren"></i> @Model.Incidentes.Count incidentes</span>
        <span><i class="ti ti-users"></i> @Model.UsuariosRiesgo.Count usuarios en riesgo</span>
        <span><i class="ti ti-device-desktop"></i> @Model.DispositivosRiesgo.Count dispositivos</span>
        <span><i class="ti ti-shield-check"></i> @Model.SecureScoreControles.Count controles recomendados</span>
      </div>

      <div class="workplan-grid">
        <div>
          <h4 class="workplan-section-title">Fuentes consultadas</h4>
          <ul class="workplan-list">
            @foreach (var source in Model.DataSources)
            {
              <li class="workplan-threat">
                <div class="workplan-threat-top">
                  <p class="workplan-item-title">@source.Name</p>
                  <span class="workplan-pill @(source.IsAvailable ? "success" : "warning")">@(source.IsAvailable ? "Disponible" : "Pendiente")</span>
                </div>
                <p class="workplan-text">@source.Count registro(s). @source.Message</p>
              </li>
            }
          </ul>
        </div>

        <div>
          <h4 class="workplan-section-title">Señales principales</h4>
          <ul class="workplan-list">
            @foreach (var alerta in Model.Alertas.Take(6))
            {
              <li class="workplan-threat">
                <div class="workplan-threat-top">
                  <p class="workplan-item-title">@alerta.Title</p>
                  <span class="workplan-pill @RiskClass(alerta.Severity)">@alerta.Severity</span>
                </div>
                <p class="workplan-text">@alerta.Category · @alerta.Status · @(alerta.Provider ?? "Microsoft Graph")</p>
                <p class="workplan-text">@((alerta.CreatedDateTime ?? alerta.LastUpdatedDateTime)?.ToLocalTime().ToString("dd MMM yyyy HH:mm", es) ?? "Sin fecha")</p>
              </li>
            }

            @foreach (var incidente in Model.Incidentes.Take(4))
            {
              <li class="workplan-threat">
                <div class="workplan-threat-top">
                  <p class="workplan-item-title">@incidente.Title</p>
                  <span class="workplan-pill @RiskClass(incidente.Severity)">@incidente.Severity</span>
                </div>
                <p class="workplan-text">@incidente.Status · @incidente.AlertCount alerta(s) asociada(s)</p>
                <p class="workplan-text">@((incidente.CreatedDateTime ?? incidente.LastUpdatedDateTime)?.ToLocalTime().ToString("dd MMM yyyy HH:mm", es) ?? "Sin fecha")</p>
              </li>
            }

            @if (!Model.Alertas.Any() && !Model.Incidentes.Any())
            {
              <li class="workplan-empty">No se encontraron alertas o incidentes puntuales en este rango.</li>
            }
          </ul>
        </div>
      </div>
    </section>
  }
</div>

@section Scripts {
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
}
