@model DigitalTechClientPortal.Models.SeguridadVM
@using System.Globalization
@{
    ViewData["Title"] = "Panel de Seguridad";

    // Cultura para fechas
    var es = CultureInfo.GetCultureInfo("es-ES");

    // Secure Score mensual: calculamos % a partir de CurrentScore y MaxScore
    var secureMonthly = Model.SecureScoreMensual?.ToList() ?? new List<DigitalTechClientPortal.Models.SecureScoreMonthly>();
    var labels = secureMonthly.Select(m => m.Label ?? "-").ToArray();
    var valuesPct = secureMonthly.Select(m =>
    {
        var current = m.CurrentScore ?? 0;
        var max = Math.Max(m.MaxScore ?? 0, 1); // evita división por cero
        var pct = 100.0 * current / max;
        return Math.Round(Math.Clamp(pct, 0, 100), 2);
    }).ToArray();

    // KPI Secure Score actual en % (usa el último registro si existe)
    double secureScoreActualPct = 0;
    if (secureMonthly.Count > 0)
    {
        var last = secureMonthly.Last();
        var lastCurrent = last.CurrentScore ?? 0;
        var lastMax = Math.Max(last.MaxScore ?? 0, 1);
        secureScoreActualPct = Math.Round(Math.Clamp(100.0 * lastCurrent / lastMax, 0, 100), 2);
    }

    // Top-N elementos para tarjetas
    int TOP = 10;
    var alertasTop = (Model.Alertas ?? new List<DigitalTechClientPortal.Models.SecurityAlert>())
        .OrderByDescending(a => a.CreatedDateTime ?? a.LastUpdatedDateTime)
        .Take(TOP)
        .ToList();

    var incidentesTop = (Model.Incidentes ?? new List<DigitalTechClientPortal.Models.SecurityIncident>())
        .OrderByDescending(i => i.CreatedDateTime ?? i.LastUpdatedDateTime)
        .Take(TOP)
        .ToList();

    var usuariosTop = (Model.UsuariosRiesgo ?? new List<DigitalTechClientPortal.Models.RiskyUser>())
        .OrderByDescending(u => u.LastUpdatedDateTime)
        .Take(TOP)
        .ToList();

    var dispositivosTop = (Model.DispositivosRiesgo ?? new List<DigitalTechClientPortal.Models.DeviceSecurityState>())
        .OrderByDescending(d => d.LastSeenDateTime)
        .Take(TOP)
        .ToList();

    var controlesTop = (Model.SecureScoreControles ?? new List<DigitalTechClientPortal.Models.SecureScoreControl>())
        .OrderByDescending(c => c.MaxScore ?? 0)
        .Take(TOP)
        .ToList();

    var simulacionesTop = (Model.SimulacionesAtaque ?? new List<DigitalTechClientPortal.Models.AttackSimulation>())
        .OrderByDescending(s => s.LaunchDateTime ?? s.CompletionDateTime)
        .Take(TOP)
        .ToList();

    // Helpers visuales (Bootstrap badges sencillos)
    Func<string?, string> SeverityClass = sev => (sev ?? "").ToLowerInvariant() switch
    {
        "critical" or "crítico" or "alta" => "text-bg-danger",
        "high" or "alto" or "media" => "text-bg-warning",
        "medium" or "medio" => "text-bg-warning",
        "low" or "baja" => "text-bg-success",
        _ => "text-bg-secondary"
    };

    Func<string?, string> RiskLevelClass = level => (level ?? "").ToLowerInvariant() switch
    {
        "critical" or "crítico" or "alto" => "text-bg-danger",
        "high" => "text-bg-danger",
        "medium" or "medio" => "text-bg-warning",
        "low" or "bajo" => "text-bg-success",
        _ => "text-bg-secondary"
    };

    bool IsHighSeverity(string? value)
    {
        var v = (value ?? "").Trim().ToLowerInvariant();
        return v is "critical" or "crítico" or "critico" or "high" or "alta" or "alto";
    }

    bool IsResolved(string? value)
    {
        var v = (value ?? "").Trim().ToLowerInvariant();
        return v is "resolved" or "resuelta" or "dismissed" or "descartada" or "closed" or "cerrado";
    }

    var dataSources = Model.DataSources?.ToList() ?? new List<DigitalTechClientPortal.Models.SecurityDataSourceStatus>();
    var permissionStatus = Model.PermissionStatus ?? new DigitalTechClientPortal.Models.SecurityPermissionStatus();
    var hasMissingPermissions = permissionStatus.HasMissingRequiredScopes;
    var availableSources = dataSources.Count(s => s.IsAvailable);
    var unavailableSources = dataSources.Where(s => !s.IsAvailable).ToList();
    var criticalAlerts = (Model.Alertas ?? new List<DigitalTechClientPortal.Models.SecurityAlert>()).Count(a => IsHighSeverity(a.Severity));
    var activeIncidents = (Model.Incidentes ?? new List<DigitalTechClientPortal.Models.SecurityIncident>()).Count(i => !IsResolved(i.Status));
    var highRiskUsers = (Model.UsuariosRiesgo ?? new List<DigitalTechClientPortal.Models.RiskyUser>()).Count(u => IsHighSeverity(u.RiskLevel));
    var deviceRiskCount = Model.DispositivosRiesgo?.Count ?? 0;
    var activeSignals = criticalAlerts + highRiskUsers + deviceRiskCount;
    var latestSignal = Model.LastSecuritySignalUtc?.ToLocalTime().ToString("dd MMM yyyy HH:mm", es) ?? "Sin señales recientes";
    var coverageLabel = hasMissingPermissions
        ? $"{permissionStatus.GrantedRequiredCount}/{permissionStatus.RequiredCount} permisos"
        : dataSources.Any() ? $"{availableSources}/{dataSources.Count} fuentes" : "Sin consulta";

    var tenantStatus = "Saludable";
    var tenantTone = "success";
    if (hasMissingPermissions)
    {
        tenantStatus = "Faltan permisos";
        tenantTone = "warning";
    }
    else if (!string.IsNullOrWhiteSpace(Model.GraphError) || unavailableSources.Count == dataSources.Count && dataSources.Any())
    {
        tenantStatus = "Sin conexión";
        tenantTone = "muted";
    }
    else if (criticalAlerts > 0 || highRiskUsers > 0)
    {
        tenantStatus = "Atención prioritaria";
        tenantTone = "danger";
    }
    else if (activeSignals > 0 || activeIncidents > 0 || unavailableSources.Any())
    {
        tenantStatus = "En observación";
        tenantTone = "warning";
    }

    var priorityActions = new List<(string Title, string Detail, string Tone, string Icon)>();
    if (criticalAlerts > 0)
        priorityActions.Add(("Revisar alertas críticas", $"{criticalAlerts} alerta(s) de severidad alta requieren triage.", "danger", "ti-alert-triangle"));
    if (highRiskUsers > 0)
        priorityActions.Add(("Validar usuarios en riesgo", $"{highRiskUsers} cuenta(s) aparecen con riesgo alto.", "danger", "ti-user-shield"));
    if (deviceRiskCount > 0)
        priorityActions.Add(("Revisar endpoints", $"{deviceRiskCount} dispositivo(s) reportan hallazgos.", "warning", "ti-device-desktop-exclamation"));
    if (secureMonthly.Any() && secureScoreActualPct < 65)
        priorityActions.Add(("Subir Secure Score", $"El tenant está en {secureScoreActualPct:0.##}%; prioriza controles de alto impacto.", "warning", "ti-chart-arrows-vertical"));
    if (hasMissingPermissions)
        priorityActions.Add(("Conceder permisos de Graph", $"{permissionStatus.MissingScopes.Count} permiso(s) faltan para leer todo el tenant.", "warning", "ti-lock-access"));
    else if (unavailableSources.Any())
        priorityActions.Add(("Completar permisos de lectura", $"{unavailableSources.Count} fuente(s) no pudieron consultarse en Graph.", "info", "ti-plug-connected-x"));
    if (!priorityActions.Any())
        priorityActions.Add(("Mantener revisión semanal", "No se detectan señales prioritarias en los datos consultados.", "success", "ti-circle-check"));

    var topControl = controlesTop.FirstOrDefault();
}

<style>
  .security-page {
    display: grid;
    gap: 18px;
  }

  .security-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.55fr);
    gap: 18px;
    align-items: stretch;
  }

  .security-panel {
    background: #ffffff;
    border: 1px solid #dbe4ef;
    border-radius: 8px;
    box-shadow: 0 8px 22px rgba(4, 16, 33, 0.08);
  }

  .security-hero-main {
    padding: 24px;
  }

  .security-eyebrow {
    margin: 0 0 8px;
    color: #65758b !important;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .security-title-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    justify-content: space-between;
  }

  .security-title {
    margin: 0;
    color: #0b1220 !important;
    font-size: 1.9rem;
    font-weight: 600;
    line-height: 1.15;
  }

  .security-copy {
    max-width: 760px;
    margin: 12px 0 0;
    color: #52647a !important;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .security-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .security-status-card {
    display: grid;
    gap: 16px;
    padding: 20px;
  }

  .security-status-top {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
  }

  .security-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    width: fit-content;
    min-height: 30px;
    padding: 0 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .security-pill.success { color: #166534; background: #dcfce7; }
  .security-pill.warning { color: #92400e; background: #fef3c7; }
  .security-pill.danger { color: #991b1b; background: #fee2e2; }
  .security-pill.info { color: #075985; background: #e0f2fe; }
  .security-pill.muted { color: #475569; background: #e2e8f0; }

  .security-score-number {
    color: #0b1220;
    font-size: 2.4rem;
    font-weight: 650;
    line-height: 1;
  }

  .security-score-label {
    margin-top: 4px;
    color: #65758b;
    font-size: 0.82rem;
  }

  .security-meta-grid,
  .security-kpi-grid {
    display: grid;
    gap: 12px;
  }

  .security-meta-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 18px;
  }

  .security-kpi-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .security-mini,
  .security-kpi {
    min-width: 0;
    padding: 15px;
    background: #f8fbff;
    border: 1px solid #e3ebf5;
    border-radius: 8px;
  }

  .security-kpi {
    background: #ffffff;
  }

  .security-label {
    margin: 0;
    color: #65758b !important;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .security-value {
    margin: 7px 0 0;
    color: #0b1220;
    font-size: 1.7rem;
    font-weight: 650;
    line-height: 1;
  }

  .security-note {
    margin: 6px 0 0;
    color: #65758b !important;
    font-size: 0.86rem;
  }

  .security-command-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr);
    gap: 18px;
  }

  .security-section-header {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    padding: 16px 18px 0;
  }

  .security-section-title {
    margin: 0;
    color: #0b1220 !important;
    font-size: 1rem;
    font-weight: 650;
  }

  .security-list {
    display: grid;
    gap: 10px;
    padding: 16px 18px 18px;
    margin: 0;
    list-style: none;
  }

  .security-action-item,
  .security-source-item {
    display: grid;
    grid-template-columns: 38px minmax(0, 1fr);
    gap: 11px;
    align-items: start;
    padding: 12px;
    background: #f8fbff;
    border: 1px solid #e3ebf5;
    border-radius: 8px;
  }

  .security-icon {
    display: inline-grid;
    width: 38px;
    height: 38px;
    place-items: center;
    color: #ffffff;
    background: #071a33;
    border-radius: 8px;
  }

  .security-icon.danger { background: #dc2626; }
  .security-icon.warning { background: #d97706; }
  .security-icon.success { background: #059669; }
  .security-icon.info { background: #0284c7; }

  .security-item-title {
    margin: 0;
    color: #0b1220 !important;
    font-size: 0.95rem;
    font-weight: 650;
  }

  .security-item-copy {
    margin: 4px 0 0;
    color: #65758b !important;
    font-size: 0.86rem;
    line-height: 1.4;
  }

  .security-chart {
    padding: 16px 18px 18px;
  }

  .security-chart-frame {
    position: relative;
    height: 240px;
  }

  .security-alert {
    padding: 14px 16px;
    color: #92400e;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 8px;
  }

  @@media (max-width: 1180px) {
    .security-hero,
    .security-command-grid,
    .security-kpi-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @@media (max-width: 760px) {
    .security-hero,
    .security-command-grid,
    .security-kpi-grid,
    .security-meta-grid {
      grid-template-columns: 1fr;
    }

    .security-title {
      font-size: 1.55rem;
    }
  }
</style>

<div class="container-fluid py-4 security-page">

  <section class="security-hero">
    <div class="security-panel security-hero-main">
      <p class="security-eyebrow">Overview del tenant</p>
      <div class="security-title-row">
        <h2 class="security-title">Panel de Seguridad</h2>
        <span class="security-pill @tenantTone">
          <i class="ti ti-shield-check"></i>
          @tenantStatus
        </span>
      </div>
      <p class="security-copy">
        Resumen de las señales principales de Microsoft Graph para entender rápidamente si el tenant está saludable, requiere seguimiento o necesita atención inmediata.
      </p>
      <div class="security-actions">
        <a class="btn btn-outline-secondary" href="javascript:location.reload()"><i class="ti ti-refresh"></i> Actualizar</a>
        <a class="btn btn-primary" href='@Url.Action("SeguridadContinuidad","Assessment")'><i class="ti ti-clipboard-check"></i> Assessment</a>
        <a class="btn btn-outline-primary" href='@Url.Action("Alertas","Seguridad")'><i class="ti ti-list-search"></i> Ver alertas</a>
      </div>
      <div class="security-meta-grid">
        <div class="security-mini">
          <p class="security-label">Última señal</p>
          <div class="security-note">@latestSignal</div>
        </div>
        <div class="security-mini">
          <p class="security-label">Cobertura</p>
          <div class="security-note">@coverageLabel consultadas</div>
        </div>
        <div class="security-mini">
          <p class="security-label">Rango</p>
          <div class="security-note">@((Model.From?.ToString("dd MMM yyyy", es) ?? "Sin inicio")) - @((Model.To?.ToString("dd MMM yyyy", es) ?? "Hoy"))</div>
        </div>
      </div>
    </div>

    <aside class="security-panel security-status-card">
      <div class="security-status-top">
        <div>
          <p class="security-label">Secure Score</p>
          <div class="security-score-number">@($"{secureScoreActualPct:0.##}%")</div>
          <div class="security-score-label">Current / Max de Microsoft Secure Score</div>
        </div>
        <span class="security-pill @(secureScoreActualPct >= 75 ? "success" : secureScoreActualPct >= 50 ? "warning" : "danger")">
          @(secureScoreActualPct >= 75 ? "Fuerte" : secureScoreActualPct >= 50 ? "Mejorable" : "Bajo")
        </span>
      </div>
      <div class="security-chart-frame">
        <canvas id="secureScoreChart"></canvas>
      </div>
    </aside>
  </section>

  @if (hasMissingPermissions)
  {
    var currentReturnUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
    <div class="security-alert">
      <div class="d-flex flex-column flex-lg-row gap-3 align-items-lg-start justify-content-between">
        <div>
          <strong>Faltan permisos de Microsoft Graph.</strong>
          <p class="mb-2 mt-1">
            El token actual tiene @permissionStatus.GrantedRequiredCount de @permissionStatus.RequiredCount permisos requeridos. Para leer todo el tenant, un administrador del cliente debe conceder los permisos pendientes.
          </p>
          <div class="d-flex flex-wrap gap-2">
            @foreach (var scope in permissionStatus.MissingScopes)
            {
              <span class="security-pill warning">
                @(permissionStatus.ScopeDescriptions.TryGetValue(scope, out var description) ? description : scope)
              </span>
            }
          </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-primary" href='@Url.Action("Consent","Login", new { returnUrl = currentReturnUrl, admin = false })'>
            <i class="ti ti-key"></i> Pedir consentimiento
          </a>
          <a class="btn btn-outline-primary" href='@Url.Action("Consent","Login", new { returnUrl = currentReturnUrl, admin = true })'>
            <i class="ti ti-shield-lock"></i> Consentimiento admin
          </a>
        </div>
      </div>
    </div>
  }
  else if (!string.IsNullOrWhiteSpace(Model.GraphError) || unavailableSources.Any())
  {
    <div class="security-alert">
      <strong>Hay fuentes sin lectura completa.</strong>
      @(Model.GraphError ?? "Algunas consultas a Microsoft Graph no respondieron correctamente. Los totales pueden estar incompletos.")
    </div>
  }

  <section class="security-kpi-grid">
    <div class="security-kpi">
      <p class="security-label">Alertas altas</p>
      <div class="security-value">@criticalAlerts</div>
      <p class="security-note">@((Model.Alertas?.Count ?? 0)) alertas consultadas</p>
    </div>
    <div class="security-kpi">
      <p class="security-label">Incidentes activos</p>
      <div class="security-value">@activeIncidents</div>
      <p class="security-note">@((Model.Incidentes?.Count ?? 0)) incidentes consultados</p>
    </div>
    <div class="security-kpi">
      <p class="security-label">Usuarios en riesgo</p>
      <div class="security-value">@((Model.UsuariosRiesgo?.Count ?? 0))</div>
      <p class="security-note">@highRiskUsers con riesgo alto</p>
    </div>
    <div class="security-kpi">
      <p class="security-label">Dispositivos</p>
      <div class="security-value">@deviceRiskCount</div>
      <p class="security-note">Endpoints con hallazgos</p>
    </div>
  </section>

  <section class="security-command-grid">
    <div class="security-panel">
      <div class="security-section-header">
        <h3 class="security-section-title">Prioridades recomendadas</h3>
        <span class="security-pill @tenantTone">@tenantStatus</span>
      </div>
      <ul class="security-list">
        @foreach (var action in priorityActions.Take(3))
        {
          <li class="security-action-item">
            <span class="security-icon @action.Tone"><i class="ti @action.Icon"></i></span>
            <div>
              <p class="security-item-title">@action.Title</p>
              <p class="security-item-copy">@action.Detail</p>
            </div>
          </li>
        }
      </ul>
    </div>

    <div class="security-panel">
      <div class="security-section-header">
        <h3 class="security-section-title">Fuentes del tenant</h3>
        <span class="security-pill @(unavailableSources.Any() ? "warning" : "success")">@coverageLabel</span>
      </div>
      <ul class="security-list">
        @if (dataSources.Any())
        {
          @foreach (var source in dataSources)
          {
            <li class="security-source-item">
              <span class="security-icon @(source.IsAvailable ? "success" : "warning")">
                <i class="ti @(source.IsAvailable ? "ti-database-check" : "ti-database-x")"></i>
              </span>
              <div>
                <p class="security-item-title">@source.Name · @source.Count registro(s)</p>
                <p class="security-item-copy">@source.Message</p>
              </div>
            </li>
          }
        }
        else
        {
          <li class="security-source-item">
            <span class="security-icon info"><i class="ti ti-database-search"></i></span>
            <div>
              <p class="security-item-title">Sin consulta disponible</p>
              <p class="security-item-copy">Todavía no hay estado de fuentes para esta carga del panel.</p>
            </div>
          </li>
        }
      </ul>
    </div>
  </section>

  <div class="security-panel">
    <div class="security-section-header">
      <h3 class="security-section-title">Evolución mensual del Secure Score</h3>
      @if (topControl != null)
      {
        <span class="security-pill info">Control sugerido: @topControl.MaxScore?.ToString("0.##") pts</span>
      }
    </div>
    <div class="security-chart">
      <div class="security-chart-frame">
        <canvas id="secureScoreChartDetail"></canvas>
      </div>
    </div>
  </div>

  <!-- Tarjetas en dos columnas desde aquí hacia abajo -->
  <div class="d-flex align-items-center justify-content-between mt-2">
    <h3 class="mb-0 fs-5">Detalle técnico</h3>
    <span class="text-muted small">Top @TOP registros por categoría</span>
  </div>
  <div class="row g-3">
    <!-- Alertas -->
    <div class="col-12 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white d-flex align-items-center justify-content-between">
          <strong>Alertas recientes</strong>
          <a class="btn btn-outline-primary btn-sm" href='@Url.Action("Alertas","Seguridad")'>Ver todas</a>
        </div>
        <div class="card-body">
          @if (alertasTop.Any())
          {
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Título</th>
                    <th>Severidad</th>
                    <th>Categoría</th>
                    <th>Estado</th>
                    <th>Proveedor</th>
                    <th>Creada</th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var a in alertasTop)
                  {
                    <tr>
                      <td>@a.Title</td>
                      <td><span class="badge @SeverityClass(a.Severity)">@a.Severity</span></td>
                      <td>@(string.IsNullOrWhiteSpace(a.Category) ? "-" : a.Category)</td>
                      <td>@(string.IsNullOrWhiteSpace(a.Status) ? "-" : a.Status)</td>
                      <td>@(string.IsNullOrWhiteSpace(a.Provider) ? "-" : a.Provider)</td>
                      <td>@(a.CreatedDateTime?.ToLocalTime().ToString("dd MMM yyyy HH:mm", es) ?? "-")</td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
            <p class="text-muted mt-2 mb-0">Mostrando @alertasTop.Count de @((Model.Alertas?.Count ?? alertasTop.Count)) alerta(s).</p>
          }
          else
          {
            <div class="text-muted">Sin alertas recientes.</div>
          }
        </div>
      </div>
    </div>

    <!-- Incidentes -->
    <div class="col-12 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white">
          <strong>Incidentes</strong>
        </div>
        <div class="card-body">
          @if (incidentesTop.Any())
          {
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Título</th>
                    <th>Severidad</th>
                    <th>Estado</th>
                    <th>Creado</th>
                    <th># Alertas</th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var i in incidentesTop)
                  {
                    <tr>
                      <td>@i.Title</td>
                      <td><span class="badge @SeverityClass(i.Severity)">@i.Severity</span></td>
