                      <td>@(a.CompletionDateTime?.ToLocalTime().ToString("dd MMM yyyy HH:mm", es) ?? "-")</td>
                      <td>@(string.IsNullOrWhiteSpace(a.Payload) ? "-" : a.Payload)</td>
