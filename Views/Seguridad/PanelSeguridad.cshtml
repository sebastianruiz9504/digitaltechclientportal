</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  (function() {
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels));
    const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(valuesPct));

    function renderSecureScoreChart(id, compact) {
      const ctx = document.getElementById(id);
      if (!ctx) return;

      const gctx = ctx.getContext('2d');
      const gradient = gctx.createLinearGradient(0, 0, 0, ctx.parentElement.clientHeight || 240);
      gradient.addColorStop(0, 'rgba(5,150,105,0.18)');
      gradient.addColorStop(1, 'rgba(5,150,105,0.02)');

      new Chart(ctx, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: 'Secure Score (%)',
            data: values,
            tension: 0.35,
            borderColor: '#059669',
            backgroundColor: gradient,
            fill: true,
            pointRadius: compact ? 0 : 2,
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false }, tooltip: { enabled: true } },
          scales: {
            y: {
              beginAtZero: true,
              max: 100,
              ticks: { display: !compact, stepSize: 20 },
              grid: { display: false }
            },
            x: {
              ticks: { display: !compact, autoSkip: true },
              grid: { display: false }
            }
          }
        }
      });
    }

    renderSecureScoreChart('secureScoreChart', true);
    renderSecureScoreChart('secureScoreChartDetail', false);
  })();
</script>
