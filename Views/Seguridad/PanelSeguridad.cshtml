    <!-- Controles de Secure Score -->
    <div class="col-12 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white">
          <strong>Controles de Secure Score</strong>
        </div>
        <div class="card-body">
