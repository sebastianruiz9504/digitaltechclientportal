.lic-head p{margin:8px 0 0;color:#d9e6e8}
.lic-kicker{display:block;font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;color:#a7f3d0}
.lic-head__meta{text-align:right;display:grid;gap:4px}
.lic-head__meta span{color:#d9e6e8}
.lic-alert{border-radius:8px;padding:12px 14px;border:1px solid}
.lic-alert.ok{background:#ecfdf5;border-color:#a7f3d0;color:#065f46}
.lic-alert.warn{background:#fff7ed;border-color:#fed7aa;color:#9a3412}
.lic-toolbar{display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap}
.lic-filter{display:flex;gap:10px;align-items:end;flex-wrap:wrap;background:#fff;border:1px solid #dbe3ea;border-radius:8px;padding:10px}
.lic-filter.compact{margin-left:auto}
.lic-filter.readonly strong{display:flex;align-items:center;height:38px;color:#111827}
.lic-filter label,.lic-card-form label,.lic-modal__card label{display:grid;gap:4px;font-size:.8rem;color:#52616b}
.lic-filter select,.lic-filter input,.lic-card-form select,.lic-card-form input,.lic-modal__card input,.lic-modal__card select,.lic-move-form select,.lic-move-form input{height:38px;border:1px solid #cbd5df;border-radius:6px;padding:0 10px;background:#fff;color:#17202a;min-width:110px}
.lic-filter select{min-width:240px}
.lic-filter input{width:92px}
.lic-icon-btn{height:38px;width:38px;display:inline-grid;place-items:center;border:0;border-radius:6px;background:#0f766e;color:#fff;cursor:pointer}
.lic-primary,.lic-secondary,.lic-link-btn{height:38px;border:0;border-radius:6px;padding:0 12px;cursor:pointer}
.lic-primary{background:#0f766e;color:#fff;display:inline-flex;align-items:center;justify-content:center;gap:6px}
.lic-secondary{background:#e2e8f0;color:#17202a}
.lic-link-btn{background:transparent;color:#0f766e;padding:0}
