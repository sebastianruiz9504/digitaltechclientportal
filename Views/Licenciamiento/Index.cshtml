@model DigitalTechClientPortal.Web.Models.LicenciamientoViewModel
@{
    ViewData["Title"] = "Licenciamiento";
    var cultura = new System.Globalization.CultureInfo("es-CO");
    var meses = cultura.DateTimeFormat.MonthNames.Take(12).Select((nombre, index) => new { Nombre = cultura.TextInfo.ToTitleCase(nombre), Numero = index + 1 }).ToList();
    Func<decimal, string> usd = value => $"USD {value.ToString("N2", cultura)}";
    var accountIdsAsignables = Model.AccountIdsDisponibles
        .Where(a => Model.AccountIdsGrupoActual.All(g => g.Id != a.Id))
        .ToList();
    var fechaHoy = DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="lic-page">
    <section class="lic-head">
        <div>
            <span class="lic-kicker">Microsoft 365 / Cloud</span>
            <h1>Licenciamiento</h1>
            <p>@Model.RazonPadreNombre</p>
        </div>
        <div class="lic-head__meta">
            <span>Cliente base: @Model.ClienteNombre</span>
            <strong>Corte @Model.FechaCorte.ToString("dd MMM yyyy", cultura)</strong>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Mensaje))
    {
        <div class="lic-alert ok">@Model.Mensaje</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="lic-alert warn">@Model.Error</div>
    }

    <section class="lic-toolbar">
        <form method="get" asp-action="Index" class="lic-filter">
            @if (Model.PuedeCambiarCliente)
            {
                <label>
                    <span>Cliente</span>
                    <select name="clienteId" onchange="this.form.submit()">
                        @foreach (var c in Model.ClientesDisponibles)
                        {
                            <option value="@c.Id" selected="@(c.Id == Model.ClienteSeleccionadoId)">@c.Nombre</option>
                        }
                    </select>
                </label>
            }
            else
            {
                <input type="hidden" name="clienteId" value="@Model.ClienteId" />
            }

            <label>
                <span>Mes</span>
                <select name="mes" onchange="this.form.submit()">
                    @foreach (var mes in meses)
                    {
                        <option value="@mes.Numero" selected="@(mes.Numero == Model.MesSeleccionado)">@mes.Nombre</option>
                    }
                </select>
            </label>

            <label>
                <span>Año</span>
                <input name="anio" value="@Model.AnioSeleccionado" inputmode="numeric" />
            </label>

            <button type="submit" class="lic-icon-btn" title="Aplicar filtros" aria-label="Aplicar filtros">
                <i class="ti ti-filter"></i>
            </button>
        </form>

        @if (Model.PuedeEditarEstructura)
        {
            <form method="post" asp-action="ActualizarFechaCorte" class="lic-filter compact">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ClienteId" value="@Model.ClienteId" />
                <input type="hidden" name="Mes" value="@Model.MesSeleccionado" />
                <input type="hidden" name="Anio" value="@Model.AnioSeleccionado" />
                <label>
                    <span>Día facturación</span>
                    <input name="DiaCorte" value="@Model.DiaCorte" inputmode="numeric" min="1" max="31" />
                </label>
                <button type="submit" class="lic-icon-btn" title="Guardar día de facturación" aria-label="Guardar día de facturación">
                    <i class="ti ti-device-floppy"></i>
                </button>
            </form>
        }
        else
        {
            <div class="lic-filter compact readonly">
                <label>
                    <span>Día facturación</span>
                    <strong>@Model.DiaCorte</strong>
                </label>
            </div>
        }

        <button type="button" class="lic-primary lic-new-request" id="openNewRequest">
            <i class="ti ti-plus"></i>
            Nueva solicitud
        </button>
    </section>

    <section class="lic-stats">
        <article><span>Licencias grupo</span><strong>@Model.TotalLicenciasPadre</strong></article>
        <article><span>Clientes hijos</span><strong>@Model.TotalClientesHijos</strong></article>
        <article><span>Account IDs</span><strong>@Model.TotalAccountIds</strong></article>
        <article><span>Prefactura</span><strong>@usd(Model.TotalPrefactura)</strong></article>
    </section>

    @if (Model.PuedeEditarEstructura)
    {
        <details class="lic-panel admin lic-collapse">
            <summary class="lic-collapse__summary">
                <div>
                    <h2>Administrar Grupo Empresarial</h2>
                    <span>Solo visible para sruiz@digitaltechcolombia.com</span>
                </div>
                <span>@Model.AccountIdsGrupoActual.Count account IDs vinculados</span>
            </summary>

            <div class="lic-admin-grid">
                <form method="post" asp-action="ActualizarGrupoEmpresarial" class="lic-card-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ClienteId" value="@Model.ClienteId" />
                    <input type="hidden" name="Mes" value="@Model.MesSeleccionado" />
                    <input type="hidden" name="Anio" value="@Model.AnioSeleccionado" />
                    <label>
                        <span>GrupoempresarialID</span>
                        <input name="GrupoEmpresarialId" value="@Model.GrupoEmpresarialId" maxlength="100" placeholder="Se genera si lo dejas vacío" />
                    </label>
                    <label>
                        <span>grupoempresarialname</span>
                        <input name="GrupoEmpresarialNombre" value="@Model.RazonPadreNombre" maxlength="200" required />
                    </label>
                    <button type="submit" class="lic-primary">Guardar relación</button>
                </form>

                <form method="post" asp-action="AsignarAccountIdGrupo" class="lic-card-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ClienteId" value="@Model.ClienteId" />
                    <input type="hidden" name="Mes" value="@Model.MesSeleccionado" />
                    <input type="hidden" name="Anio" value="@Model.AnioSeleccionado" />
                    <input type="hidden" name="GrupoEmpresarialId" value="@Model.GrupoEmpresarialId" />
                    <input type="hidden" name="GrupoEmpresarialNombre" value="@Model.RazonPadreNombre" />
                    <label>
                        <span>Agregar Account ID / cliente hijo</span>
                        <select name="AccountIdRowId" required>
                            <option value="">Seleccionar...</option>
                            @foreach (var account in accountIdsAsignables)
                            {
                                var grupo = string.IsNullOrWhiteSpace(account.GrupoEmpresarialNombre)
                                    ? "sin grupo"
                                    : account.GrupoEmpresarialNombre;
                                <option value="@account.Id">@account.Display (@grupo)</option>
                            }
                        </select>
                    </label>
                    <button type="submit" class="lic-primary">Asignar al grupo</button>
                </form>
            </div>

            <div class="lic-table-wrap">
                <table class="lic-table">
                    <thead>
                        <tr>
                            <th>Account ID</th>
                            <th>Cliente hijo</th>
                            <th>Grupo</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var account in Model.AccountIdsGrupoActual)
                        {
                            <tr>
                                <td>@account.AccountId</td>
                                <td>@account.ClienteNombre</td>
                                <td>@account.GrupoEmpresarialNombre</td>
                                <td class="lic-actions-cell">
                                    <form method="post" asp-action="QuitarAccountIdGrupo">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ClienteId" value="@Model.ClienteId" />
                                        <input type="hidden" name="AccountIdRowId" value="@account.Id" />
                                        <input type="hidden" name="Mes" value="@Model.MesSeleccionado" />
                                        <input type="hidden" name="Anio" value="@Model.AnioSeleccionado" />
                                        <button type="submit" class="lic-link-btn">Quitar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (Model.AccountIdsGrupoActual.Count == 0)
                        {
                            <tr><td colspan="4">No hay Account IDs vinculados a este grupo.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>
    }

    <section class="lic-grid">
        <details class="lic-panel lic-collapse">
            <summary class="lic-collapse__summary">
                <div>
                    <h2>Razón Padre</h2>
                    <span>Productos agrupados por SKU/nombre y precio unitario</span>
                </div>
                <span>@Model.ProductosRazonPadre.Count líneas · @Model.TotalLicenciasPadre licencias</span>
            </summary>
            <div class="lic-table-wrap">
                <table class="lic-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Total</th>
                            <th>USD unitario</th>
                            <th>Clientes</th>
                            <th>Account IDs</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.ProductosRazonPadre)
                        {
                            <tr>
                                <td>@p.Producto</td>
                                <td><span class="lic-pill">@p.CantidadTotal</span></td>
                                <td>@usd(p.PrecioUnitarioUsd)</td>
                                <td>@string.Join(", ", p.ClientesConProducto)</td>
                                <td class="muted">@string.Join(", ", p.AccountIds)</td>
                            </tr>
                        }
                        @if (Model.ProductosRazonPadre.Count == 0)
                        {
                            <tr><td colspan="5">No hay productos cloud activos para este grupo.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>

        <details class="lic-panel lic-collapse">
            <summary class="lic-collapse__summary">
                <div>
                    <h2>Clientes Hijos</h2>
                    <span>Consulta de productos y prorrateos asociados a cada cliente hijo</span>
                </div>
                <span>@Model.ClientesHijos.Count clientes · @usd(Model.TotalPrefactura)</span>
            </summary>
            <div class="lic-child-list">
                @foreach (var cliente in Model.ClientesHijos)
                {
                    <details class="lic-child">
                        <summary class="lic-child__head">
                            <div>
                                <h3>@cliente.ClienteNombre</h3>
                                <span>Account IDs: @(cliente.AccountIds.Count == 0 ? "Sin account ID registrado" : string.Join(", ", cliente.AccountIds))</span>
                            </div>
                            <strong>@cliente.TotalLicencias licencias · @usd(cliente.TotalPrefactura)</strong>
                        </summary>

                        <div class="lic-table-wrap slim">
                            <table class="lic-table">
                                <thead>
                                    <tr>
                                        <th>Producto</th>
                                        <th>Cantidad</th>
                                        <th>Días</th>
                                        <th>USD unitario</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var c in cliente.Consumo.OrderBy(x => x.Producto).ThenBy(x => x.EsProrrateoSolicitud))
                                    {
                                        <tr>
                                            <td>
                                                @c.Producto
                                                @if (c.EsProrrateoSolicitud)
                                                {
                                                    <span class="lic-tag">prorrateo</span>
                                                }
                                            </td>
                                            <td>@c.Cantidad</td>
                                            <td>@c.DiasConsumo / @c.DiasMes</td>
                                            <td>@usd(c.PrecioUnitarioUsd)</td>
                                            <td>@usd(c.TotalProrrateadoUsd)</td>
                                        </tr>
                                    }
                                    @if (cliente.Consumo.Count == 0)
                                    {
                                        <tr><td colspan="5">Sin productos cloud activos.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </details>
                }
                @if (Model.ClientesHijos.Count == 0)
                {
                    <div class="lic-empty">No hay clientes hijos vinculados a este grupo empresarial.</div>
                }
            </div>
        </details>
    </section>

    <section class="lic-panel">
        <div class="lic-panel__head">
            <div>
                <h2>Histórico De Solicitudes</h2>
                <span>Las solicitudes quedan asociadas al cliente hijo para prorrateo</span>
            </div>
            <span>@Model.HistoricoSolicitudes.Count registros</span>
        </div>
        <div class="lic-table-wrap">
            <table class="lic-table">
                <thead>
                    <tr>
                        <th>Creada</th>
                        <th>Aprovisionamiento</th>
                        <th>Solicitante</th>
                        <th>Cliente hijo</th>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>USD unitario</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in Model.HistoricoSolicitudes)
                    {
                        <tr>
                            <td>@(h.FechaSolicitud?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>@(h.FechaAprovisionamiento?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>@h.SolicitadoPor</td>
                            <td>@h.ClienteHijo</td>
                            <td>@h.Producto</td>
                            <td>+@h.CantidadNueva</td>
                            <td>@usd(h.PrecioUnitarioUsd)</td>
                            <td><span class="lic-status">@h.Estado</span></td>
                        </tr>
                    }
                    @if (Model.HistoricoSolicitudes.Count == 0)
                    {
                        <tr><td colspan="8">Sin solicitudes registradas.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<div class="lic-modal" id="licenseModal" aria-hidden="true">
    <form method="post" asp-action="CrearSolicitudCliente" class="lic-modal__card">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ClienteId" value="@Model.ClienteId" />
        <input type="hidden" name="SalesRecordId" id="requestSalesRecordId" />
        <input type="hidden" name="Mes" value="@Model.MesSeleccionado" />
        <input type="hidden" name="Anio" value="@Model.AnioSeleccionado" />
        <div>
            <h2>Nueva solicitud</h2>
            <p>Estado inicial: Pendiente</p>
        </div>
        <label>
            <span>Hijo</span>
            <select name="ClienteHijoId" id="requestChild" required>
                <option value="">Seleccionar hijo...</option>
                @foreach (var cliente in Model.ClientesHijos)
                {
                    <option value="@cliente.ClienteId">@cliente.ClienteNombre</option>
                }
            </select>
        </label>
        <label>
            <span>Producto</span>
            <select id="requestProduct" required>
                <option value="">Seleccionar producto...</option>
                @foreach (var producto in Model.ProductosSolicitud)
                {
                    <option value="@producto.SalesRecordId" data-child="@producto.ClienteId">
                        @producto.Producto · @producto.ClienteNombre · @usd(producto.PrecioUnitarioUsd)
                    </option>
                }
                <option value="__otro" data-child="">Otro</option>
            </select>
        </label>
        <label class="lic-manual-product" id="manualProductWrap">
            <span>Producto otro</span>
            <input name="ProductoManual" id="manualProduct" maxlength="250" placeholder="Escribe el producto" />
        </label>
        <label>
            <span>Cantidad</span>
            <input name="Cantidad" type="number" min="1" value="1" required />
        </label>
        <label>
            <span>Fecha de aprovisionamiento</span>
            <input name="FechaAprovisionamiento" type="date" value="@fechaHoy" required />
        </label>
        <div class="lic-modal__actions">
            <button type="button" class="lic-secondary" id="closeModal">Cancelar</button>
            <button type="submit" class="lic-primary">Enviar</button>
        </div>
    </form>
</div>

<style>
