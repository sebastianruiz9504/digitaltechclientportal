  .lic-panel,.lic-head{padding:14px}
  .lic-filter label,.lic-filter select,.lic-filter input{width:100%;min-width:0}
  .lic-icon-btn{width:100%}
  .lic-child__head,.lic-panel__head,.lic-collapse__summary{display:grid}
  .lic-child__head strong{text-align:left}
  .lic-move-form{grid-template-columns:1fr}
}
</style>

<script>
    (() => {
        const modal = document.getElementById('licenseModal');
        const close = document.getElementById('closeModal');
        const open = document.getElementById('openNewRequest');
        const child = document.getElementById('requestChild');
        const product = document.getElementById('requestProduct');
        const record = document.getElementById('requestSalesRecordId');
        const manualWrap = document.getElementById('manualProductWrap');
        const manual = document.getElementById('manualProduct');

        const syncProduct = () => {
            const isOther = product.value === '__otro';
            record.value = isOther ? '' : product.value;
            manualWrap.classList.toggle('visible', isOther);
            manual.required = isOther;
            if (!isOther) {
                manual.value = '';
            }
        };

        const syncProductsByChild = () => {
            const selectedChild = child.value;
            Array.from(product.options).forEach((option) => {
                const isPlaceholder = option.value === '';
                const isOther = option.value === '__otro';
                const belongs = !selectedChild || option.dataset.child === selectedChild;
                const visible = isPlaceholder || isOther || belongs;
                option.hidden = !visible;
                option.disabled = !visible;
            });

            if (product.selectedOptions.length && product.selectedOptions[0].disabled) {
                product.value = '';
            }

            syncProduct();
        };

        open.addEventListener('click', () => {
            modal.classList.add('open');
            modal.setAttribute('aria-hidden', 'false');
            syncProductsByChild();
        });
        child.addEventListener('change', syncProductsByChild);
        product.addEventListener('change', syncProduct);
        close.addEventListener('click', () => {
            modal.classList.remove('open');
            modal.setAttribute('aria-hidden', 'true');
        });
        modal.addEventListener('click', (event) => {
            if (event.target === modal) {
                close.click();
            }
        });
    })();
</script>
