@model DigitalTechClientPortal.Models.ImpresorasVm

@{
    ViewData["Title"] = "Impresoras";

    string FormatDate(DateTime? date) => date.HasValue ? date.Value.ToString("dd/MM/yyyy") : "—";
    string FormatMonth(DateTime date) => date.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-CO"));
    string FormatNumber(long value) => value.ToString("N0", new System.Globalization.CultureInfo("es-CO"));
    bool IsLecturaReciente(DateTime? date) => date.HasValue && date.Value.Date >= DateTime.Today.AddDays(-5);
}

<div class="w-full px-4 sm:px-6 lg:px-8 py-8">
  <header class="mb-4">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Impresoras</h1>
    <p class="mt-1 text-slate-500">Consulta tus impresoras, mantenimientos y contadores.</p>
  </header>

  @if (TempData["ImpresorasError"] != null)
  {
    <div class="rounded-lg bg-yellow-50 border border-yellow-200 p-4 text-sm text-yellow-800 mb-4">
      @TempData["ImpresorasError"]
    </div>
  }

  @if (Model.PuedeFiltrarPorCliente && Model.Clientes.Any())
  {
    <form method="get" class="mb-4">
      <label for="clienteId" class="block text-sm font-medium text-slate-700 mb-1">Filtrar por cliente</label>
      <div class="flex gap-2 items-center">
        <select id="clienteId" name="clienteId" class="w-full max-w-md rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-800" onchange="this.form.submit()">
          <option value="">Todos los clientes</option>
          @foreach (var cliente in Model.Clientes)
          {
            if (Model.ClienteSeleccionadoId == cliente.Id)
            {
              <option value="@cliente.Id" selected>@cliente.Nombre</option>
            }
            else
            {
              <option value="@cliente.Id">@cliente.Nombre</option>
            }
          }
        </select>
      </div>
    </form>
  }


  @if (Model.PuedeFiltrarPorCliente && Model.ConsumosMensuales.Any())
  {
    <section class="mb-6 rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-4 py-3">
        <h2 class="text-base font-semibold text-slate-900">Consumo mensual por equipo</h2>
        <p class="text-xs text-slate-600">Se consolida un único consumo por mes para cada serial, incluso cuando hay múltiples lecturas en el mismo mes.</p>
      </div>
      <div class="overflow-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-600">
            <tr>
              <th class="px-4 py-2 text-left">Periodo</th>
              <th class="px-4 py-2 text-left">Cliente</th>
              <th class="px-4 py-2 text-left">Serial</th>
              <th class="px-4 py-2 text-right">Consumo páginas</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            @foreach (var consumo in Model.ConsumosMensuales)
            {
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-2 text-slate-700">@FormatMonth(consumo.Periodo)</td>
                <td class="px-4 py-2 text-slate-700">@(string.IsNullOrWhiteSpace(consumo.ClienteNombre) ? "—" : consumo.ClienteNombre)</td>
                <td class="px-4 py-2 font-semibold text-slate-900">@consumo.Serial</td>
                <td class="px-4 py-2 text-right font-semibold text-slate-900">@FormatNumber(consumo.ConsumoPaginas)</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </section>
  }

  @if (Model.Impresoras == null || !Model.Impresoras.Any())
  {
    <div class="rounded-2xl border border-slate-200 bg-white p-6 text-slate-600">
      No se encontraron impresoras asociadas a tu cuenta.
    </div>
  }
  else
  {
    <div class="mb-4">
      <label for="estadoCirculo" class="block text-sm font-medium text-slate-700 mb-1">Filtrar por estado del círculo</label>
      <select id="estadoCirculo" class="w-full max-w-xs rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-800">
        <option value="todos">Todos</option>
        <option value="verde">Habilitada (verde)</option>
        <option value="rojo">Desconectado (rojo)</option>
      </select>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      @foreach (var impresora in Model.Impresoras)
      {
        var lecturaReciente = IsLecturaReciente(impresora.FechaUltimaLectura);
        var estadoCirculo = lecturaReciente ? "verde" : "rojo";
        var estadoTexto = lecturaReciente ? "Habilitada" : "Desconectado";

        <div class="impresora-card rounded-xl border border-slate-200 bg-white shadow-sm flex flex-col" data-estado-circulo="@estadoCirculo">
          <div class="p-4 border-b border-slate-100">
            <p class="text-xs uppercase tracking-wide text-slate-500">Cliente</p>
            <p class="text-sm font-semibold text-slate-900">@(string.IsNullOrWhiteSpace(impresora.ClienteNombre) ? "—" : impresora.ClienteNombre)</p>

            <div class="mt-2 flex items-start justify-between gap-3">
              <div>
                <p class="text-[11px] uppercase tracking-wide text-slate-500">Serial</p>
                <h2 class="text-lg font-semibold text-slate-900 leading-tight">@impresora.Serial</h2>
                <p class="text-xs text-slate-600">@impresora.Referencia</p>
              </div>
              <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-medium text-slate-700">@impresora.Categoria</span>
            </div>

            <dl class="mt-3 grid grid-cols-2 gap-x-4 gap-y-2 text-xs text-slate-700">
              <div>
                <dt class="text-slate-500">Último nivel de tóner</dt>
                <dd class="font-semibold text-slate-900">@(string.IsNullOrWhiteSpace(impresora.UltimoNivelToner) ? "—" : impresora.UltimoNivelToner)</dd>
              </div>
              <div>
                <dt class="text-slate-500">Fecha de lectura</dt>
                <dd class="font-semibold text-slate-900 inline-flex items-center gap-2">
                  <span class="inline-block h-2.5 w-2.5 rounded-full @(lecturaReciente ? "bg-emerald-500" : "bg-red-500")" title="@(lecturaReciente ? "Lectura reciente" : "Lectura vencida o sin fecha")"></span>
                  <span>@FormatDate(impresora.FechaUltimaLectura)</span>
                </dd>
                <dd class="text-[11px] text-slate-600 col-span-2">Estado: <span class="font-semibold text-slate-800">@estadoTexto</span></dd>
              </div>
            </dl>
          </div>

          <div class="p-4 border-b border-slate-100">
            <h3 class="text-sm font-semibold text-slate-800 mb-2">Contadores</h3>
            @if (impresora.Contadores == null || !impresora.Contadores.Any())
            {
              <p class="text-xs text-slate-500">Sin contadores registrados.</p>
            }
            else
            {
              <div class="space-y-2 max-h-40 overflow-auto pr-1">
                @foreach (var c in impresora.Contadores)
                {
                  <div class="rounded-lg border border-slate-200 bg-slate-50 p-2.5">
                    <div class="flex items-center justify-between text-[11px] text-slate-600">
                      <span>@c.Periodo</span>
                      <span>@FormatDate(c.FechaLectura)</span>
                    </div>
                    <dl class="mt-1.5 grid grid-cols-2 gap-1.5 text-xs">
                      <div><dt class="text-slate-500">Contador</dt><dd class="font-semibold text-slate-900">@c.ContadorPaginas</dd></div>
                      <div><dt class="text-slate-500">Escaneos</dt><dd class="font-semibold text-slate-900">@c.Escaneos</dd></div>
                      <div><dt class="text-slate-500">Nivel tóner</dt><dd class="font-semibold text-slate-900">@c.NivelToner</dd></div>
                      <div><dt class="text-slate-500">IP</dt><dd class="font-semibold text-slate-900">@c.IpAddress</dd></div>
                    </dl>
                  </div>
                }
              </div>
            }
          </div>

          <details class="group">
            <summary class="cursor-pointer select-none px-4 py-3 flex items-center justify-between text-sm font-semibold text-slate-800 bg-slate-50">
              <span>Mantenimientos</span>
              <span class="text-slate-500 group-open:hidden"><i class="ti ti-chevron-down"></i></span>
              <span class="text-slate-500 hidden group-open:inline"><i class="ti ti-chevron-up"></i></span>
            </summary>
            <div class="px-4 pb-4 pt-2 space-y-2 bg-white">
              @if (impresora.Mantenimientos == null || !impresora.Mantenimientos.Any())
              {
                <p class="text-xs text-slate-500">Esta impresora no tiene mantenimientos registrados.</p>
              }
              else
              {
                @foreach (var m in impresora.Mantenimientos)
                {
                  <div class="rounded-lg border border-slate-200 bg-slate-50 p-2.5">
                    <div class="flex items-center justify-between text-[11px] text-slate-600">
                      <span>@FormatDate(m.FechaMantenimiento)</span>
                      @if (m.TieneActa && m.Id != Guid.Empty)
                      {
                        <a class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800" asp-action="DescargarActa" asp-route-id="@m.Id">
                          <i class="ti ti-file-download"></i><span>Acta</span>
                        </a>
                      }
                    </div>
                    <h4 class="mt-0.5 text-xs font-semibold text-slate-900">@m.Titulo</h4>
                    <p class="mt-0.5 text-xs text-slate-600">@m.Descripcion</p>
                  </div>
                }
              }
            </div>
          </details>
        </div>
      }
    </div>
  }
</div>

<script>
  (() => {
    const estadoCirculo = document.getElementById('estadoCirculo');
    if (!estadoCirculo) return;

    const cards = Array.from(document.querySelectorAll('.impresora-card'));
    estadoCirculo.addEventListener('change', () => {
      const valor = estadoCirculo.value;
      cards.forEach((card) => {
        const estado = card.getAttribute('data-estado-circulo');
        card.style.display = valor === 'todos' || estado === valor ? '' : 'none';
      });
    });
  })();
</script>
