@model DigitalTechClientPortal.Models.ImpresorasVm

@{
    ViewData["Title"] = "Impresoras";

    string FormatDate(DateTime? date) => date.HasValue ? date.Value.ToString("dd/MM/yyyy") : "—";
}

<div class="w-full px-4 sm:px-6 lg:px-8 py-8">
  <header class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Impresoras</h1>
    <p class="mt-2 text-slate-500">Consulta tus impresoras, mantenimientos y contadores.</p>
  </header>

  @if (TempData["ImpresorasError"] != null)
  {
    <div class="rounded-lg bg-yellow-50 border border-yellow-200 p-4 text-sm text-yellow-800 mb-6">
      @TempData["ImpresorasError"]
    </div>
  }

  @if (Model.Impresoras == null || !Model.Impresoras.Any())
  {
    <div class="rounded-2xl border border-slate-200 bg-white p-6 text-slate-600">
      No se encontraron impresoras asociadas a tu cuenta.
    </div>
  }
  else
  {
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      @foreach (var impresora in Model.Impresoras)
      {
        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm flex flex-col">
          <div class="p-5 border-b border-slate-100">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs uppercase tracking-wide text-slate-500">Serial</p>
                <h2 class="text-xl font-semibold text-slate-900">@impresora.Serial</h2>
                <p class="text-sm text-slate-500">@impresora.Referencia</p>
              </div>
              <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">@impresora.Categoria</span>
            </div>
            <dl class="mt-4 grid grid-cols-2 gap-x-6 gap-y-2 text-sm text-slate-700">
              <div>
                <dt class="text-slate-500">Último nivel de tóner</dt>
                <dd class="font-medium">@(string.IsNullOrWhiteSpace(impresora.UltimoNivelToner) ? "—" : impresora.UltimoNivelToner)</dd>
              </div>
              <div>
                <dt class="text-slate-500">Fecha de lectura</dt>
                <dd class="font-medium">@FormatDate(impresora.FechaUltimaLectura)</dd>
              </div>
            </dl>
          </div>

          <div class="p-5 border-b border-slate-100">
            <h3 class="text-sm font-semibold text-slate-800 mb-3">Contadores</h3>
            @if (impresora.Contadores == null || !impresora.Contadores.Any())
            {
              <p class="text-sm text-slate-500">Sin contadores registrados.</p>
            }
            else
            {
              <div class="space-y-3 max-h-48 overflow-auto pr-1">
                @foreach (var c in impresora.Contadores)
                {
                  <div class="rounded-lg border border-slate-200 p-3">
                    <div class="flex items-center justify-between text-xs text-slate-500">
                      <span>@c.Periodo</span>
                      <span>@FormatDate(c.FechaLectura)</span>
                    </div>
                    <dl class="mt-2 grid grid-cols-2 gap-2 text-sm">
                      <div>
                        <dt class="text-slate-500">Contador</dt>
                        <dd class="font-medium">@c.ContadorPaginas</dd>
                      </div>
                      <div>
                        <dt class="text-slate-500">Escaneos</dt>
                        <dd class="font-medium">@c.Escaneos</dd>
                      </div>
                      <div>
                        <dt class="text-slate-500">Nivel tóner</dt>
                        <dd class="font-medium">@c.NivelToner</dd>
                      </div>
                      <div>
                        <dt class="text-slate-500">IP</dt>
                        <dd class="font-medium">@c.IpAddress</dd>
                      </div>
                    </dl>
                  </div>
                }
              </div>
            }
          </div>

          <details class="group">
            <summary class="cursor-pointer select-none px-5 py-4 flex items-center justify-between text-sm font-semibold text-slate-800">
              <span>Mantenimientos</span>
              <span class="text-slate-500 group-open:hidden"><i class="ti ti-chevron-down"></i></span>
              <span class="text-slate-500 hidden group-open:inline"><i class="ti ti-chevron-up"></i></span>
            </summary>
            <div class="px-5 pb-5 space-y-3">
              @if (impresora.Mantenimientos == null || !impresora.Mantenimientos.Any())
              {
                <p class="text-sm text-slate-500">Esta impresora no tiene mantenimientos registrados.</p>
              }
              else
              {
                @foreach (var m in impresora.Mantenimientos)
                {
                  <div class="rounded-lg border border-slate-200 p-3">
                    <div class="flex items-center justify-between text-xs text-slate-500">
                      <span>@FormatDate(m.FechaMantenimiento)</span>
                      @if (m.TieneActa && m.Id != Guid.Empty)
                      {
                        <a class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800" asp-action="DescargarActa" asp-route-id="@m.Id">
                          <i class="ti ti-file-download"></i><span>Acta</span>
                        </a>
                      }
                    </div>
                    <h4 class="mt-1 text-sm font-semibold text-slate-900">@m.Titulo</h4>
                    <p class="mt-1 text-sm text-slate-600">@m.Descripcion</p>
                  </div>
                }
              }
            </div>
          </details>
        </div>
      }
    </div>
  }
</div>