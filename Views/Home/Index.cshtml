@model List<DigitalTechClientPortal.Models.ProductVm>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inicio";

    var resumen = ViewBag.Summary as DigitalTechClientPortal.Models.ResumenDto ?? new DigitalTechClientPortal.Models.ResumenDto();
    var selectedRange = (DigitalTechClientPortal.Models.RangoResumen)(ViewBag.SelectedRange ?? DigitalTechClientPortal.Models.RangoResumen.Mes);
    var copiers = ViewBag.Copiers as List<DigitalTechClientPortal.Models.ProductVm>;

    string RangeToString(DigitalTechClientPortal.Models.RangoResumen r) => r switch
    {
        DigitalTechClientPortal.Models.RangoResumen.Mes => "mes",
        DigitalTechClientPortal.Models.RangoResumen.Anio => "anio",
        DigitalTechClientPortal.Models.RangoResumen.Total => "total",
        _ => "mes"
    };

    var currentRange = RangeToString(selectedRange);
    string baseUrl = Url.Action("Index", "Home") ?? "/Home/Index";
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css" />
}

@section Main {
<div class="home-page">
    <section class="home-hero">
        <div>
            <span class="home-eyebrow">
                <i class="ti ti-layout-dashboard"></i>
                Portal operativo
            </span>
            <h1 class="home-title">Digital Tech Client Portal</h1>
            <p class="home-lead">
                Consulta tus servicios, tickets, consumos, reportes y productos desde una experiencia más limpia,
                rápida de leer y enfocada en las tareas del día a día.
            </p>

            <div class="home-actions">
                <a href="@Url.Action("Index","Soporte")" class="home-button">
                    <i class="ti ti-headset"></i>
                    Soporte
                </a>
                <a href="https://wa.me/573153405758" target="_blank" rel="noopener noreferrer" class="home-button-secondary">
                    <i class="ti ti-brand-whatsapp"></i>
                    Hablar con un asesor
                </a>
            </div>
        </div>

        <aside class="home-kpi-panel" aria-label="Resumen de servicio">
            <div class="home-kpi-header">
                <div>
                    <p class="home-kpi-subtitle">Resumen</p>
                    <h2 class="home-kpi-title">KPI de servicio</h2>
                </div>
                <div class="home-range-tabs" aria-label="Rango de resumen">
                    <a class="home-range-tab @(currentRange == "mes" ? "active" : "")" href="@($"{baseUrl}?range=mes")">Mes</a>
                    <a class="home-range-tab @(currentRange == "anio" ? "active" : "")" href="@($"{baseUrl}?range=anio")">Año</a>
                    <a class="home-range-tab @(currentRange == "total" ? "active" : "")" href="@($"{baseUrl}?range=total")">Total</a>
                </div>
            </div>

            @if (TempData["SummaryError"] != null)
            {
                <div class="home-error mt-3">@TempData["SummaryError"]</div>
            }

            <div class="home-kpi-grid">
                <a href="@Url.Action("Index","Soporte")" class="home-metric" aria-label="Ir a soporte por horas entregadas">
                    <div>
                        <p class="home-metric-label">Horas entregadas</p>
                        <p class="home-metric-value">@resumen.HorasEntregadas</p>
                        <p class="home-metric-copy">Capacitaciones, tickets, implementaciones y consultorías.</p>
                    </div>
                </a>

                <div class="home-mini-stack">
                    <a href="@Url.Action("Index","Soporte")" class="home-mini-metric" aria-label="Ir a soporte por tickets cloud">
                        <div>
                            <p class="home-metric-label">Tickets Cloud</p>
                            <p class="home-metric-value">@resumen.TicketsCloud</p>
                        </div>
                    </a>
                    <a href="@Url.Action("Index","Soporte")" class="home-mini-metric" aria-label="Ir a soporte por tickets copiers">
                        <div>
                            <p class="home-metric-label">Tickets Copiers</p>
                            <p class="home-metric-value">@resumen.TicketsCopiers</p>
                        </div>
                    </a>
                </div>

                <a href="@Url.Action("Index","Capacitaciones")" class="home-mini-metric" aria-label="Ir a capacitaciones">
                    <div>
                        <p class="home-metric-label">Capacitaciones</p>
                        <p class="home-metric-value">@resumen.Capacitaciones</p>
                    </div>
                </a>

                <a href="@Url.Action("Index","Reportes")" class="home-mini-metric" aria-label="Ir a reportes">
                    <div>
                        <p class="home-metric-label">Reportes Cloud</p>
                        <p class="home-metric-value">@resumen.Reportes</p>
                    </div>
                </a>
            </div>
        </aside>
    </section>

    <section class="home-section">
        <div class="home-section-header">
            <div>
                <p class="home-section-kicker">Productos y licencias</p>
                <h2 class="home-section-title">Verticales activas</h2>
            </div>
            <a href="https://wa.me/573153405758" target="_blank" rel="noopener noreferrer" class="home-section-action">
                <i class="ti ti-plus"></i>
                Solicitar productos
            </a>
        </div>

        <div class="home-product-grid">
            <article class="home-product-card">
                <div class="home-card-header">
                    <div class="flex items-center gap-3 min-w-0">
                        <div class="home-card-logo">
                            <img
                                src="https://logo.clearbit.com/kyocera.com"
                                alt="Kyocera"
                                referrerpolicy="no-referrer"
                                onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=&quot;ti ti-printer text-xl text-slate-700&quot;></i>';" />
                        </div>
                        <div class="min-w-0">
                            <p class="home-section-kicker">Impresión inteligente</p>
                            <h3 class="home-card-title">Copiers</h3>
                        </div>
                    </div>
                    <span class="home-icon amber"><i class="ti ti-printer"></i></span>
                </div>

                @if (TempData["CopiersError"] != null)
                {
                    <div class="home-error mt-3">@TempData["CopiersError"]</div>
                }
                else if (copiers == null || copiers.Count == 0)
                {
                    <div class="home-empty mt-3">No hay productos para mostrar.</div>
                }
                else
                {
                    <ul class="home-list thin-scroll">
                        @foreach (var p in copiers)
                        {
                            <li class="home-list-item">
                                <span class="home-list-name">@p.ProductName</span>
                                <span class="home-chip">@p.Quantity</span>
                            </li>
                        }
                    </ul>
                }

                <a href="https://wa.me/573153405758" target="_blank" rel="noopener noreferrer" class="home-card-link">
                    <i class="ti ti-arrow-up-right"></i>
                    Solicitar más unidades
                </a>
            </article>

            <article class="home-product-card">
                <div class="home-card-header">
                    <div class="flex items-center gap-3 min-w-0">
                        <div class="home-card-logo">
                            <img
                                src="https://logo.clearbit.com/microsoft.com"
                                alt="Microsoft"
                                referrerpolicy="no-referrer"
                                onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=&quot;ti ti-brand-windows text-xl text-slate-700&quot;></i>';" />
                        </div>
                        <div class="min-w-0">
                            <p class="home-section-kicker">Nube y productividad</p>
                            <h3 class="home-card-title">Cloud</h3>
                        </div>
                    </div>
                    <span class="home-icon cyan"><i class="ti ti-cloud"></i></span>
                </div>

                @if (TempData["HomeError"] != null)
                {
                    <div class="home-error mt-3">@TempData["HomeError"]</div>
                }
                else if (Model == null || Model.Count == 0)
                {
                    <div class="home-empty mt-3">No hay productos para mostrar.</div>
                }
                else
                {
                    <ul class="home-list thin-scroll">
                        @foreach (var p in Model)
                        {
                            <li class="home-list-item">
                                <span class="home-list-name">@p.ProductName</span>
                                <span class="home-chip">@p.Quantity</span>
                            </li>
                        }
                    </ul>
                }

                <a href="https://wa.me/573153405758" target="_blank" rel="noopener noreferrer" class="home-card-link">
                    <i class="ti ti-arrow-up-right"></i>
                    Ampliar licenciamiento
                </a>
            </article>
        </div>
    </section>

    <section class="home-section">
        <div class="home-section-header">
            <div>
                <p class="home-section-kicker">Actualizaciones</p>
                <h2 class="home-section-title">Noticias y promociones</h2>
            </div>
        </div>

        <div class="home-news-card">
            <div class="home-card-header">
                <div class="home-news-pagination swiper-pagination !static"></div>
                <div class="home-news-controls">
                    <button class="home-swiper-button promo-prev" type="button" aria-label="Anterior">
                        <i class="ti ti-chevron-left"></i>
                    </button>
                    <button class="home-swiper-button promo-next" type="button" aria-label="Siguiente">
                        <i class="ti ti-chevron-right"></i>
                    </button>
                </div>
            </div>

            <div id="promoSwiper" class="swiper">
                <div class="swiper-wrapper">
                    <div class="swiper-slide">
                        <div class="home-promo-frame">
                            <img
                                src="https://41741943.fs1.hubspotusercontent-na1.net/hubfs/41741943/3%201.png"
                                alt="Promoción Kyocera 2025"
                                loading="lazy"
                                decoding="async"
                                onerror="this.src='https://placehold.co/1200x515/ffffff/65758b?text=Imagen+no+disponible';" />
                        </div>
                    </div>

                    <div class="swiper-slide">
                        <div class="home-promo-frame">
                            <img
                                src="https://41741943.fs1.hubspotusercontent-na1.net/hubfs/41741943/2%201.png"
                                alt="Licenciamiento Microsoft 365"
                                loading="lazy"
                                decoding="async"
                                onerror="this.src='https://placehold.co/1200x515/ffffff/65758b?text=Imagen+no+disponible';" />
                        </div>
                    </div>

                    <div class="swiper-slide">
                        <div class="home-promo-frame">
                            <img
                                src="https://41741943.fs1.hubspotusercontent-na1.net/hubfs/41741943/1-Oct-15-2025-04-07-41-8388-PM.png"
                                alt="Azure Backup 50% Off"
                                loading="lazy"
                                decoding="async"
                                onerror="this.src='https://placehold.co/1200x515/ffffff/65758b?text=Imagen+no+disponible';" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<script defer src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const swiper = new Swiper('#promoSwiper', {
            slidesPerView: 1,
            spaceBetween: 0,
            loop: true,
            observer: true,
            observeParents: true,
            autoplay: { delay: 4200, disableOnInteraction: false },
            pagination: { el: '.home-news-pagination', clickable: true },
            navigation: { nextEl: '.promo-next', prevEl: '.promo-prev' },
            on: {
                imagesReady() { swiper.update(); },
                resize() { swiper.update(); }
            }
        });
    });
</script>
}
