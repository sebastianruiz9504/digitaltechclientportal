@model DigitalTechClientPortal.Models.M365GovernanceVm
@using System.Globalization
@{
    ViewData["Title"] = "Plan de optimización Microsoft 365";
    var es = CultureInfo.GetCultureInfo("es-CO");
    var plan = Model.OptimizationPlanAi;
    string Tone(string? value) => (value ?? "").ToLowerInvariant() switch
    {
        "critico" or "crítico" or "alta" or "alto" => "danger",
        "media" or "medio" => "warning",
        "baja" or "bajo" => "success",
        _ => "muted"
    };
}

<style>
  .opt-page { display: grid; gap: 18px; }
  .opt-panel { background: #fff; border: 1px solid #dbe4ef; border-radius: 8px; box-shadow: 0 8px 22px rgba(4,16,33,.07); }
  .opt-head { display: grid; grid-template-columns: minmax(0,1fr) auto; gap: 14px; align-items: start; padding: 22px; }
  .opt-eyebrow { margin: 0 0 7px; color: #64748b; font-size: .75rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
  .opt-title { margin: 0; color: #0f172a; font-size: 1.75rem; font-weight: 650; line-height: 1.18; }
  .opt-copy { margin: 10px 0 0; color: #52647a; line-height: 1.5; max-width: 860px; }
  .opt-actions { display: flex; flex-wrap: wrap; gap: 8px; justify-content: flex-end; }
  .opt-grid { display: grid; grid-template-columns: minmax(0, .42fr) minmax(0, .58fr); gap: 16px; align-items: start; }
  .opt-section { padding: 18px; }
  .opt-section-title { margin: 0 0 12px; color: #0f172a; font-size: 1.05rem; font-weight: 650; }
  .opt-chip { display: inline-flex; align-items: center; min-height: 26px; padding: 0 9px; border-radius: 999px; font-size: .75rem; font-weight: 700; white-space: nowrap; }
  .opt-chip.danger { color: #991b1b; background: #fee2e2; }
  .opt-chip.warning { color: #92400e; background: #fef3c7; }
  .opt-chip.success { color: #166534; background: #dcfce7; }
  .opt-chip.info { color: #075985; background: #e0f2fe; }
  .opt-chip.muted { color: #475569; background: #e2e8f0; }
  .opt-kpis { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 12px; }
  .opt-kpi { padding: 15px; min-height: 108px; }
  .opt-label { margin: 0; color: #64748b; font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
  .opt-number { color: #0f172a; font-size: 1.65rem; font-weight: 700; line-height: 1.05; }
  .opt-note { color: #64748b; font-size: .86rem; }
  .opt-list { display: grid; gap: 10px; }
  .opt-row { display: grid; gap: 7px; padding: 13px; border: 1px solid #e2e8f0; border-radius: 8px; background: #f8fafc; }
  .opt-row-top { display: flex; gap: 8px; align-items: center; justify-content: space-between; }
  .opt-row-title { color: #172033; font-weight: 650; }
  .opt-steps { display: grid; gap: 8px; margin-top: 8px; }
  .opt-step { display: grid; grid-template-columns: 28px minmax(0,1fr); gap: 9px; align-items: start; }
  .opt-step-num { width: 28px; height: 28px; display: inline-grid; place-items: center; border-radius: 50%; background: #dbeafe; color: #1d4ed8; font-weight: 800; font-size: .78rem; }
  @@media (max-width: 1100px) { .opt-grid, .opt-head { grid-template-columns: 1fr; } .opt-actions { justify-content: flex-start; } .opt-kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @@media (max-width: 640px) { .opt-kpis { grid-template-columns: 1fr; } }
</style>

<div class="container-fluid py-4 opt-page">
  <section class="opt-panel opt-head">
    <div>
      <p class="opt-eyebrow">Plan AI de optimización</p>
      <h1 class="opt-title">Acciones recomendadas para mejorar uso y gobierno</h1>
      <p class="opt-copy">
        Plan generado a partir de reportes Microsoft 365 del período @Model.Period. No estima costos: se enfoca en adopción, limpieza, almacenamiento, gobierno y operación.
      </p>
    </div>
    <div class="opt-actions">
      <a class="btn btn-outline-secondary" href='@Url.Action("Index","Gobierno", new { period = Model.Period })'><i class="ti ti-arrow-left"></i> Volver</a>
      <a class="btn btn-outline-primary" href='@Url.Action("PlanOptimizacion","Gobierno", new { period = Model.Period })'><i class="ti ti-refresh"></i> Regenerar</a>
    </div>
  </section>

  <section class="opt-kpis">
    <div class="opt-panel opt-kpi"><div class="opt-number">@Model.AvailableLicenses</div><p class="opt-label">Licencias libres</p><div class="opt-note">@Model.AssignedLicenses asignadas</div></div>
    <div class="opt-panel opt-kpi"><div class="opt-number">@Model.UsersWithoutCoreActivity.Count</div><p class="opt-label">Usuarios sin actividad</p><div class="opt-note">Servicios core</div></div>
    <div class="opt-panel opt-kpi"><div class="opt-number">@Model.LargeInactiveSharePointSites.Count</div><p class="opt-label">Sitios inactivos</p><div class="opt-note">SharePoint +1 GB</div></div>
    <div class="opt-panel opt-kpi"><div class="opt-number">@Model.UnassignedPolicies.Count</div><p class="opt-label">Políticas sin asignar</p><div class="opt-note">Intune</div></div>
    <div class="opt-panel opt-kpi"><div class="opt-number">@Model.StaleOrNonCompliantDevices.Count</div><p class="opt-label">Dispositivos a revisar</p><div class="opt-note">@Model.GeneratedAtLocal</div></div>
  </section>

  @if (!string.IsNullOrWhiteSpace(Model.AiPlanError))
  {
    <div class="alert alert-warning mb-0">@Model.AiPlanError</div>
  }

  @if (plan == null)
  {
    <section class="opt-panel opt-section">
      <h2 class="opt-section-title">Plan no disponible</h2>
      <p class="opt-note mb-0">No se pudo generar el plan AI, pero el dashboard de Gobierno M365 conserva los hallazgos calculados.</p>
    </section>
  }
  else
  {
    <section class="opt-grid">
      <aside class="opt-panel opt-section">
        <div class="opt-row-top mb-3">
          <h2 class="opt-section-title mb-0">Resumen ejecutivo</h2>
          <span class="opt-chip @Tone(plan.OptimizationLevel)">@plan.OptimizationLevel</span>
        </div>
        <p class="opt-copy">@plan.ExecutiveSummary</p>
        <div class="opt-row mt-3">
          <div class="opt-row-title">Criterio de priorización</div>
          <div class="opt-note">@plan.OptimizationRationale</div>
        </div>
        @if (plan.MissingData.Any())
        {
          <h3 class="opt-section-title mt-4">Datos faltantes</h3>
          <div class="opt-list">
            @foreach (var item in plan.MissingData)
            {
              <div class="opt-row"><div class="opt-note">@item</div></div>
            }
          </div>
        }
      </aside>

      <div class="opt-panel opt-section">
        <h2 class="opt-section-title">Hallazgos clave</h2>
        <div class="opt-list">
          @foreach (var finding in plan.KeyFindings)
          {
            <div class="opt-row">
              <div class="opt-row-top">
                <span class="opt-row-title">@finding.Title</span>
                <span class="opt-chip info">@finding.Area</span>
              </div>
              <div class="opt-note">@finding.PlainLanguageSummary</div>
              <div class="opt-note"><strong>Población:</strong> @finding.AffectedPopulation</div>
              <div class="opt-note"><strong>Impacto:</strong> @finding.WhyItMatters</div>
            </div>
          }
        </div>
      </div>
    </section>

    <section class="opt-panel opt-section">
      <h2 class="opt-section-title">Acciones priorizadas</h2>
      <div class="opt-list">
        @foreach (var action in plan.Actions)
        {
          <div class="opt-row">
            <div class="opt-row-top">
              <span class="opt-row-title">@action.Title</span>
              <span class="opt-chip @Tone(action.Priority)">@action.Priority</span>
            </div>
            <div class="opt-note"><strong>@action.Area:</strong> @action.BusinessOutcome</div>
            <div class="opt-note">Responsable sugerido: @action.Owner · Esfuerzo: @action.Effort</div>
            <div class="opt-steps">
              @foreach (var step in action.Steps.OrderBy(s => s.Order))
              {
                <div class="opt-step">
                  <span class="opt-step-num">@step.Order</span>
                  <div>
                    <div class="opt-row-title">@step.Portal · @step.ClickPath</div>
                    <div class="opt-note">@step.Instruction</div>
                    <div class="opt-note"><strong>Validación:</strong> @step.Validation</div>
                  </div>
                </div>
              }
            </div>
          </div>
        }
      </div>
    </section>

    @if (plan.Assumptions.Any())
    {
      <section class="opt-panel opt-section">
        <h2 class="opt-section-title">Supuestos</h2>
        <div class="opt-list">
          @foreach (var item in plan.Assumptions)
          {
            <div class="opt-row"><div class="opt-note">@item</div></div>
          }
        </div>
      </section>
    }
  }

  <section class="opt-panel opt-section">
    <h2 class="opt-section-title">Hallazgos calculados por el portal</h2>
    <div class="opt-list">
      @foreach (var item in Model.Opportunities.Take(10))
      {
        <div class="opt-row">
          <div class="opt-row-top"><span class="opt-row-title">@item.Title</span><span class="opt-chip @Tone(item.Severity)">@item.Severity</span></div>
          <div class="opt-note">@item.Area · @item.Detail</div>
          <div class="opt-note">@item.RecommendedAction</div>
        </div>
      }
    </div>
  </section>
</div>
