@{
    Layout = null;
    var returnUrl = Context.Request.Query["returnUrl"].FirstOrDefault() ?? "/";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Iniciar sesión · Digital Tech</title>

    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-body">
    <main class="login-shell">
        <section class="login-card" aria-labelledby="login-title">
            <img src="~/logosloganblack.png" alt="Digital Tech" class="login-logo" />

            <h1 id="login-title" class="login-title">Bienvenido</h1>
            <p class="login-copy">Accede con tu cuenta Microsoft para continuar.</p>

            <a href="@Url.Action("SignIn","Login", new { returnUrl })" class="login-button">
                <span class="login-ms-mark" aria-hidden="true">
                    <svg viewBox="0 0 23 23" xmlns="http://www.w3.org/2000/svg">
                        <rect width="10" height="10" x="0" y="0" fill="#F35325" />
                        <rect width="10" height="10" x="12" y="0" fill="#81BC06" />
                        <rect width="10" height="10" x="0" y="12" fill="#05A6F0" />
                        <rect width="10" height="10" x="12" y="12" fill="#FFBA08" />
                    </svg>
                </span>
                Entrar con Microsoft
            </a>

            <a href="https://account.microsoft.com/account" target="_blank" rel="noopener" class="login-help">
                ¿Problemas para iniciar sesión?
            </a>
        </section>

        <p class="login-footer">© @DateTime.UtcNow.Year Digital Tech</p>
    </main>
</body>
</html>
