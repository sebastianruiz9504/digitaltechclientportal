@using DigitalTechClientPortal.Security
@using DigitalTechClientPortal.Services
@inject DigitalTechClientPortal.Services.DataverseClienteService ClienteService
@inject DigitalTechClientPortal.Services.PortalPermissionService PermissionService

@{
    var title = ViewData["Title"]?.ToString() ?? "Dashboard · Digital Tech";
    var currentController = Context.Request.RouteValues["controller"]?.ToString() ?? "";
    var currentAction = Context.Request.RouteValues["action"]?.ToString() ?? "";

    Func<string, string, bool> isActive = (ctrl, act) =>
        string.Equals(currentController, ctrl, StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, act, StringComparison.OrdinalIgnoreCase);

    Func<string, string, string> navClasses = (ctrl, act) =>
        "app-nav-link " + (isActive(ctrl, act) ? "is-active" : "");

    var candidateEmails = UserEmailResolver.GetCandidateEmails(User);
    var email = candidateEmails.FirstOrDefault();

    dynamic? cliente = null;
    foreach (var candidateEmail in candidateEmails)
    {
        try
        {
            cliente = await ClienteService.GetClienteByEmailAsync(candidateEmail);
            if (cliente != null)
            {
                email = candidateEmail;
                break;
            }
        }
        catch { }
    }

    var access = PortalAccessContext.Empty;
    try
    {
        access = await PermissionService.GetAccessForEmailsAsync(candidateEmails);
    }
    catch
    {
        access = PortalAccessContext.Empty;
    }
    var companyName = (string)(cliente?.Nombre ?? access.ClienteNombre ?? "Digital Tech");
    var workspaceName = email ?? string.Empty;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var displayName = User.Identity?.Name ?? email ?? string.Empty;
    var isLimited = access.IsLimited;
    var canManagePermissions = access.IsPrincipal
        || (access.IsLimited
            && access.IsActive
            && PortalModuleKeys.AllKeys.All(moduleKey => access.AllowedModules.Contains(moduleKey)));
    Func<string, bool> canAccessModule = moduleKey =>
        !isLimited || (access.IsActive && access.AllowedModules.Contains(moduleKey));

    var usuariosContadores = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "jromero@digitaltechcolombia.com",
        "germanruiz@digitaltechcolombia.com",
        "sruiz@digitaltechcolombia.com"
    };
    var canSeeContadores = candidateEmails.Any(candidateEmail => usuariosContadores.Contains(candidateEmail));
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@title</title>

    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Inter', 'Helvetica Neue', 'Arial', 'ui-sans-serif', 'system-ui']
                    }
                }
            }
        }
    </script>

    @RenderSection("Head", required: false)
</head>
<body class="app-body font-sans antialiased">
    <div class="app-shell">
        <aside id="sidebar" class="app-sidebar thin-scroll">
            <div class="app-brand">
                <div class="app-brand-mark">
                    <img src="~/favicon.png" alt="Digital Tech" />
                </div>
                <div class="app-brand-copy">
                    <div class="app-brand-kicker">Digital Tech</div>
                    <div class="app-brand-title">@companyName</div>
                    <div class="app-brand-subtitle">@workspaceName</div>
                </div>
            </div>

            <nav class="app-nav" aria-label="Navegación principal">
                <p class="app-nav-heading nav-text">Menú</p>
                <ul>
                    <li>
                        <a class='@navClasses("Home","Index")' href='@Url.Action("Index","Home")' title="Inicio">
                            <i class="ti ti-home"></i><span class="nav-text">Inicio</span>
                        </a>
                    </li>

                    @if (canManagePermissions)
                    {
                        <li>
                            <a class='@navClasses("Permisos","Index")' href='@Url.Action("Index","Permisos")' title="Permisos">
                                <i class="ti ti-users-group"></i><span class="nav-text">Permisos</span>
                            </a>
                        </li>
                    }

                    @if (canAccessModule(PortalModuleKeys.Facturacion))
                    {
                        <li>
                            <a class='@navClasses("Facturacion","Index")' href='@Url.Action("Index","Facturacion", new { email = email })' title="Facturación">
                                <i class="ti ti-file-invoice"></i><span class="nav-text">Facturación</span>
                            </a>
                        </li>
                    }

                    @if (canAccessModule(PortalModuleKeys.Capacitaciones))
                    {
                        <li>
                            <a class='@navClasses("Capacitaciones","Index")' href='@Url.Action("Index","Capacitaciones")' title="Capacitaciones">
                                <i class="ti ti-school"></i><span class="nav-text">Capacitaciones</span>
                            </a>
                        </li>
                    }
                    @if (canAccessModule(PortalModuleKeys.Academy))
                    {
                        <li>
                            <a class='@navClasses("Academy","Index")' href='@Url.Action("Index","Academy")' title="Academy">
                                <i class="ti ti-book"></i><span class="nav-text">Academy</span>
                            </a>
                        </li>
                    }
                    @if (canAccessModule(PortalModuleKeys.Reportes))
                    {
                        <li>
                            <a class='@navClasses("Reportes","Index")' href='@Url.Action("Index","Reportes")' title="Reportes">
                                <i class="ti ti-report"></i><span class="nav-text">Reportes</span>
                            </a>
                        </li>
                    }
                    @if (canAccessModule(PortalModuleKeys.Soporte))
                    {
                        <li>
                            <a class='@navClasses("Soporte","Index")' href='@Url.Action("Index","Soporte")' title="Soporte">
                                <i class="ti ti-headset"></i><span class="nav-text">Soporte</span>
                            </a>
                        </li>
                    }
                    @if (canAccessModule(PortalModuleKeys.Seguridad))
                    {
                        <li>
                            <a class='@navClasses("Seguridad","Panel")' href='@Url.Action("Panel","Seguridad")' title="Seguridad">
                                <i class="ti ti-shield-lock"></i><span class="nav-text">Seguridad</span>
                            </a>
                        </li>
                    }
                    @if (canAccessModule(PortalModuleKeys.Gobierno))
                    {
                        <li>
                            <a class='@navClasses("Gobierno","Index")' href='@Url.Action("Index","Gobierno")' title="Gobierno Microsoft 365">
                                <i class="ti ti-chart-pie"></i><span class="nav-text">Gobierno M365</span>
                            </a>
                        </li>
                    }
                    @if (canAccessModule(PortalModuleKeys.Inventario))
                    {
                        <li>
                            <a class='@navClasses("Inventario","Equipos")' href='@Url.Action("Equipos","Inventario")' title="Inventario">
                                <i class="ti ti-device-desktop"></i><span class="nav-text">Inventario</span>
                            </a>
                        </li>
                    }
                    @if (canAccessModule(PortalModuleKeys.Impresoras))
                    {
                        <li>
                            <a class='@navClasses("Impresoras","Index")' href='@Url.Action("Index","Impresoras")' title="Impresoras">
                                <i class="ti ti-printer"></i><span class="nav-text">Impresoras</span>
                            </a>
                        </li>
                    }
                    @if (canSeeContadores)
                    {
                        <li>
                            <a class='@navClasses("Contadores","Index")' href='@Url.Action("Index","Contadores")' title="Contadores">
                                <i class="ti ti-calculator"></i><span class="nav-text">Contadores</span>
                            </a>
                        </li>
                    }
                </ul>

                <p class="app-nav-heading nav-text">Productos</p>
                <ul>
                    <li>
                        <a class='@navClasses("PortafolioCloud","Index")' href='@Url.Action("Index","PortafolioCloud")' title="Cloud">
                            <i class="ti ti-cloud"></i><span class="nav-text">Cloud</span>
                        </a>
                    </li>
                    <li>
                        <a class='@navClasses("PortafolioCopiers","Index")' href='@Url.Action("Index","PortafolioCopiers")' title="Impresión">
                            <i class="ti ti-printer"></i><span class="nav-text">Impresión</span>
                        </a>
                    </li>
                    <li>
                        <a class='@navClasses("ServiciosProfesionales","Index")' href='@Url.Action("Index","ServiciosProfesionales")' title="Servicios Profesionales">
                            <i class="ti ti-briefcase"></i><span class="nav-text">Servicios Profesionales</span>
                        </a>
                    </li>
                </ul>

                <div class="app-nav-footer">
                    <a href='@Url.Action("SeguridadContinuidad","Assessment")' class="app-nav-cta" title="Assessment">
                        <i class="ti ti-clipboard-check"></i><span class="nav-text">Assessment</span>
                    </a>
                </div>
            </nav>
        </aside>

        <div class="app-content-shell">
            <header class="app-topbar">
                <button id="sidebarToggle" class="app-icon-button" type="button" aria-label="Mostrar u ocultar menú">
                    <i class="ti ti-layout-sidebar-left-collapse"></i>
                </button>

                <a href="/Support/SoporteTest" class="app-assistant-button" title="CloudIA">
                    <i class="ti ti-message-chatbot"></i><span>CloudIA</span>
                </a>

                <div class="app-topbar-spacer"></div>

                @if (isAuthenticated)
                {
                    <span class="app-user-name">@displayName</span>
                    <form method="post" action='@Url.Action("SignOutUser","Login")' class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="app-button app-button-primary">
                            <i class="ti ti-logout"></i><span>Salir</span>
                        </button>
                    </form>
                }
                else
                {
                    <a href='@Url.Action("SignIn","Login")' class="app-button app-button-primary">
                        <i class="ti ti-login"></i><span>Entrar</span>
                    </a>
                }
            </header>

            <main role="main" class="app-main">
                @RenderBody()
                @RenderSection("Main", required: false)
            </main>

            <script src="~/js/site.js" asp-append-version="true"></script>
            @RenderSection("Scripts", required: false)
        </div>
    </div>

    <script>
        (function () {
            const btn = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');

            if (!btn || !sidebar) return;

            const saved = localStorage.getItem('sidebar-collapsed');
            const startsCompact = window.matchMedia('(max-width: 640px)').matches;
            if (saved === 'true' || (saved === null && startsCompact)) {
                sidebar.classList.add('collapsed');
            }

            btn.addEventListener('click', function () {
                sidebar.classList.toggle('collapsed');
                localStorage.setItem('sidebar-collapsed', sidebar.classList.contains('collapsed'));
            });
        })();
    </script>
</body>
</html>
